---
/**
 * Hero.astro
 *
 * Reusable hero for marketing pages. Slot accepts a right-side control surface
 * (typically a list of MetricRows in a panel). If no slot is provided, the
 * hero renders single-column.
 */

interface Cta {
  label: string;
  href: string;
  /** Optional data- attributes (e.g. GA4 download tracking hooks). */
  data?: Record<string, string>;
}

interface Props {
  eyebrow: string;
  headline: string;
  sub: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  /** Optional third CTA, rendered as a ghost button after the secondary. */
  tertiaryCta?: Cta;
  headlineSize?: "xl" | "lg";
  headlineWrap?: "default" | "compact";
  compactCtas?: boolean;
}

const {
  eyebrow,
  headline,
  sub,
  primaryCta,
  secondaryCta,
  tertiaryCta,
  headlineSize = "xl",
  headlineWrap = "default",
  compactCtas = false,
} = Astro.props;
const hasPanel = Astro.slots.has("panel");
---

<section class={`hero ${hasPanel ? "hero--split" : "hero--solo"} ${headlineWrap === "compact" ? "hero--compact-headline" : ""} ${compactCtas ? "hero--compact-ctas" : ""}`}>
  {/* Quiet proof field. Keep the page specific to Alfred without the generic
      animated-grid/scanline treatment common in generated dev-tool sites. */}
  <div class="m-aurora hero__field" aria-hidden="true"></div>
  <div class="m-container hero__inner">
    <div class="hero__copy">
      <div class="m-eyebrow">{eyebrow}</div>
      <h1 class={headlineSize === "xl" ? "m-display-xl" : "m-display-lg"}>{headline}</h1>
      <p class="m-body-lg hero__sub">{sub}</p>
      {(primaryCta || secondaryCta || tertiaryCta) && (
        <div class="hero__ctas">
          {primaryCta && <a class="m-btn" href={primaryCta.href} rel="noopener" {...primaryCta.data}>{primaryCta.label}</a>}
          {secondaryCta && (
            <a class="m-btn m-btn--ghost" href={secondaryCta.href} rel="noopener" {...secondaryCta.data}>{secondaryCta.label}</a>
          )}
          {tertiaryCta && (
            <a class="m-btn m-btn--ghost" href={tertiaryCta.href} rel="noopener" {...tertiaryCta.data}>{tertiaryCta.label}</a>
          )}
        </div>
      )}
    </div>
    {hasPanel && (
      <aside class="hero__panel">
        <slot name="panel" />
      </aside>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 66px 0 48px;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 56px;
    align-items: start;
  }

  .hero--split .hero__inner {
    grid-template-columns: minmax(0, 0.92fr) minmax(380px, 0.68fr);
  }

  .hero__copy h1 {
    margin-top: 18px;
    color: var(--alfred-text-bright);
  }

  .hero--compact-headline .hero__copy h1 { max-width: 17ch; }

  .hero__field::before { opacity: 0.34; filter: blur(18px) saturate(0.78); }
  .hero__field::after { opacity: 0.2; }

  .hero__copy,
  .hero__panel {
    min-width: 0;
  }

  .hero__sub {
    margin-top: 24px;
    color: var(--alfred-text);
    max-width: 52ch;
    overflow-wrap: normal;
  }

  .hero__ctas {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero__panel {
    position: relative;
    background: var(--glass-fill-strong);
    background: color-mix(in oklab, var(--glass-solid) 72%, transparent);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    border: 1px solid var(--glass-edge);
    border-radius: 0;
    padding: 20px;
    box-shadow: 0 32px 90px -38px rgba(0, 0, 0, 0.9), var(--glass-glow);
  }

  @supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
    .hero__panel { background: var(--glass-solid); }
  }

  /* Luminous top edge on the floating telemetry panel. */
  .hero__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(180deg, var(--glass-edge-lit), transparent 48%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .hero__panel > :global(*) { position: relative; z-index: 1; }

  @media (max-width: 980px) {
    .hero { padding: 46px 0 26px; }
    .hero__inner { gap: 28px; }
    .hero--split .hero__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .hero { padding: 44px 0 23px; }
    .hero__inner { gap: 22px; }
    .hero__inner,
    .hero__copy,
    .hero__panel,
    .hero__sub,
    .hero__ctas {
      max-width: 100%;
    }
    .hero__copy h1 {
      max-width: min(100%, 17ch);
      text-wrap: pretty;
    }
    .hero__copy h1 { margin-top: 16px; }
    .hero__sub { margin-top: 18px; }
    .hero__ctas { margin-top: 24px; }
    .hero__panel { padding: 16px; }
    .hero__sub {
      overflow-wrap: normal;
      word-break: normal;
    }
    .hero--compact-ctas .hero__ctas {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 82px), 1fr));
      gap: 8px;
    }
    .hero--compact-ctas .hero__ctas .m-btn {
      justify-content: center;
      padding-left: 6px;
      padding-right: 6px;
      min-width: 0;
      font-size: 14px;
    }
  }

  @media (max-width: 360px) {
    .hero { padding-bottom: 6px; }
    .hero__inner { gap: 16px; }
    .hero__ctas { margin-top: 18px; }
    .hero__panel { padding: 14px; }
  }

  /* Calm staged entrance for the hero copy + panel. Each lifts in once on
     load. Tiny, single-shot, and disabled under reduced motion. */
  .hero__copy > * {
    animation: hero-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__copy .m-eyebrow { animation-delay: 0.02s; }
  .hero__copy h1 { animation-delay: 0.1s; }
  .hero__sub { animation-delay: 0.2s; }
  .hero__ctas { animation-delay: 0.3s; }
  .hero__panel { animation: hero-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.34s both; }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__copy > *,
    .hero__panel { animation: none; }
  }
</style>
