---
/**
 * Hero.astro
 *
 * Reusable hero for marketing pages. Slot accepts a right-side control surface
 * (typically a list of MetricRows in a panel). If no slot is provided, the
 * hero renders single-column.
 */

interface Cta {
  label: string;
  href: string;
  /** Optional data- attributes (e.g. GA4 download tracking hooks). */
  data?: Record<string, string>;
}

interface Props {
  eyebrow: string;
  headline: string;
  sub: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  /** Optional third CTA, rendered as a ghost button after the secondary. */
  tertiaryCta?: Cta;
  headlineSize?: "xl" | "lg";
  headlineWrap?: "default" | "compact";
}

const {
  eyebrow,
  headline,
  sub,
  primaryCta,
  secondaryCta,
  tertiaryCta,
  headlineSize = "xl",
  headlineWrap = "default",
} = Astro.props;
const hasPanel = Astro.slots.has("panel");
---

<section class={`hero ${hasPanel ? "hero--split" : "hero--solo"} ${headlineWrap === "compact" ? "hero--compact-headline" : ""}`}>
  {/* Aurora field: two drifting brand blooms + a soft status-lane texture.
      This is the Glass x Systematic backdrop the whole hero floats on. */}
  <div class="m-aurora" aria-hidden="true"></div>
  {/* Cinematic fleet layer: a calm horizon sweep. Pure CSS, no JS,
      reduced-motion safe. Reads as "the fleet is working in the background"
      without competing with the headline. */}
  <div class="hero-fleet" aria-hidden="true">
    <span class="hero-fleet__sweep"></span>
  </div>
  <div class="m-container hero__inner">
    <div class="hero__copy">
      <div class="m-eyebrow">{eyebrow}</div>
      <h1 class={headlineSize === "xl" ? "m-display-xl" : "m-display-lg"}>{headline}</h1>
      <p class="m-body-lg hero__sub">{sub}</p>
      {(primaryCta || secondaryCta || tertiaryCta) && (
        <div class="hero__ctas">
          {primaryCta && <a class="m-btn" href={primaryCta.href} rel="noopener" {...primaryCta.data}>{primaryCta.label}</a>}
          {secondaryCta && (
            <a class="m-btn m-btn--ghost" href={secondaryCta.href} rel="noopener" {...secondaryCta.data}>{secondaryCta.label}</a>
          )}
          {tertiaryCta && (
            <a class="m-btn m-btn--ghost" href={tertiaryCta.href} rel="noopener" {...tertiaryCta.data}>{tertiaryCta.label}</a>
          )}
        </div>
      )}
    </div>
    {hasPanel && (
      <aside class="hero__panel">
        <slot name="panel" />
      </aside>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 44px;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 56px;
    align-items: start;
  }

  .hero--split .hero__inner {
    grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.78fr);
  }

  .hero__copy h1 {
    margin-top: 18px;
    color: var(--alfred-text-bright);
  }

  .hero--compact-headline .hero__copy h1 {
    max-width: 17ch;
  }

  .hero__copy,
  .hero__panel {
    min-width: 0;
  }

  .hero__sub {
    margin-top: 24px;
    color: var(--alfred-text);
    max-width: 52ch;
    overflow-wrap: normal;
  }

  .hero__ctas {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero__panel {
    position: relative;
    background: var(--glass-fill-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    border: 1px solid var(--glass-edge);
    border-radius: 0;
    padding: 26px;
    box-shadow: var(--glass-shadow), var(--glass-glow);
  }

  /* Stacked pane: a second, fainter sheet of glass offset behind the
     telemetry panel. Sells layered translucent depth, not a flat card. */
  .hero__panel::after {
    content: "";
    position: absolute;
    top: 22px;
    left: 22px;
    right: -22px;
    bottom: -22px;
    z-index: -1;
    background: var(--glass-fill);
    border: 1px solid var(--glass-edge);
    box-shadow: var(--glass-shadow);
    pointer-events: none;
  }

  @media (max-width: 980px) {
    /* The offset sheet would collide with stacked content on small
       screens; the panel reads as a single pane there. */
    .hero__panel::after { display: none; }
  }

  @supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
    .hero__panel { background: var(--glass-solid); }
  }

  /* Luminous top edge on the floating telemetry panel. */
  .hero__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(180deg, var(--glass-edge-lit), transparent 48%);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .hero__panel > :global(*) { position: relative; z-index: 1; }

  @media (max-width: 980px) {
    .hero { padding: 64px 0 48px; }
    .hero--split .hero__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .hero__inner,
    .hero__copy,
    .hero__panel,
    .hero__sub,
    .hero__ctas {
      max-width: 100%;
    }
    .hero__copy h1 {
      max-width: 13ch;
      text-wrap: pretty;
    }
    .hero__sub {
      overflow-wrap: normal;
      word-break: normal;
    }
    .hero__ctas {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 112px), 1fr));
    }
    .hero__ctas .m-btn {
      justify-content: center;
      padding-left: 12px;
      padding-right: 12px;
      min-width: 0;
    }
  }

  /* ───────────────────────────────────────────────────────────────
     Cinematic fleet layer. Sits above .m-ambient (the drifting grid)
     and below the hero copy. A faint horizon sweep crosses the hero on
     a long loop. It is decorative, low-opacity, and no-ops under
     prefers-reduced-motion.
     ─────────────────────────────────────────────────────────────── */
  .hero-fleet {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-fleet__sweep {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -30%;
    width: 30%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 229, 199, 0.05) 45%,
      rgba(0, 229, 199, 0.09) 50%,
      rgba(0, 229, 199, 0.05) 55%,
      transparent 100%
    );
    filter: blur(2px);
    animation: hero-sweep 11s ease-in-out infinite;
  }
  :global([data-theme="light"]) .hero-fleet__sweep {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(15, 138, 120, 0.05) 45%,
      rgba(15, 138, 120, 0.08) 50%,
      rgba(15, 138, 120, 0.05) 55%,
      transparent 100%
    );
  }
  @keyframes hero-sweep {
    0%   { transform: translateX(0); opacity: 0; }
    12%  { opacity: 1; }
    88%  { opacity: 1; }
    100% { transform: translateX(440%); opacity: 0; }
  }

  /* Calm staged entrance for the hero copy + panel. Each lifts in once on
     load. Tiny, single-shot, and disabled under reduced motion. */
  .hero__copy > * {
    animation: hero-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .hero__copy .m-eyebrow { animation-delay: 0.02s; }
  .hero__copy h1 { animation-delay: 0.1s; }
  .hero__sub { animation-delay: 0.2s; }
  .hero__ctas { animation-delay: 0.3s; }
  .hero__panel { animation: hero-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.34s both; }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fleet__sweep { animation: none; }
    .hero-fleet__sweep { opacity: 0; }
    .hero__copy > *,
    .hero__panel { animation: none; }
  }
</style>
