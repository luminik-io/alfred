# Forwarded flags whose values are secrets (setup-token forwards --token,
# architect setup forwards --slack-bot-token). Timeout diagnostics must never
# echo these values into stderr or captured logs.
_SECRET_ARG_FLAGS = frozenset({"--token", "--slack-bot-token"})
_SECRET_ARG_PLACEHOLDER = "[redacted]"


def _redact_secret_args(cmd: list[str]) -> list[str]:
    """Return ``cmd`` with values of secret flags replaced for safe logging.

    Handles both ``--flag value`` and ``--flag=value`` forms.
    """
    redacted: list[str] = []
    skip_next = False
    for arg in cmd:
        if skip_next:
            redacted.append(_SECRET_ARG_PLACEHOLDER)
            skip_next = False
            continue
        flag, eq, _value = arg.partition("=")
        if flag in _SECRET_ARG_FLAGS:
            if eq:
                redacted.append(f"{flag}={_SECRET_ARG_PLACEHOLDER}")
            else:
                redacted.append(arg)
                skip_next = True
            continue
        redacted.append(arg)
    return redacted


def _run_subcommand(
    cmd: list[str],
    *,
    timeout: float | None,
    env: dict[str, str] | None = None,
) -> int:
    process = subprocess.Popen(cmd, env=env, start_new_session=True)

    def _terminate_on_signal(signum: int, _frame: Any) -> None:
        _terminate_process_group(process)
        raise SystemExit(128 + signum)

    previous_handlers = {
        signum: signal.signal(signum, _terminate_on_signal)
        for signum in (signal.SIGTERM, signal.SIGHUP)
    }
    try:
        return process.wait() if timeout is None else process.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        _terminate_process_group(process)
        print(
            f"alfred: command timed out after {timeout:g}s: {shlex.join(_redact_secret_args(cmd))}",
            file=sys.stderr,
        )
        return 124
    except KeyboardInterrupt:
        _terminate_process_group(process)
        raise
    finally:
        for signum, previous in previous_handlers.items():
            signal.signal(signum, previous)


def _terminate_process_group(process: subprocess.Popen[Any]) -> None:
    try:
        os.killpg(process.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    with contextlib.suppress(subprocess.TimeoutExpired):
        process.wait(timeout=2)
    with contextlib.suppress(ProcessLookupError):
        os.killpg(process.pid, signal.SIGKILL)
    process.wait()


def _switch_value(raw: str) -> str:
    value = raw.strip()
    comment_at = value.find("#")
    if comment_at > 0 and value[comment_at - 1].isspace():
        value = value[:comment_at].strip()
    return value.lower()


