    if args.show_tool_calls:
        cmd.append("--show-tool-calls")
    if args.json:
        cmd.append("--json")
    return _run_subcommand(cmd, timeout=_DELEGATED_COMMAND_TIMEOUT_S)


def cmd_brain(args: argparse.Namespace) -> int:
    script = _HERE / "alfred-brain.py"
