        help="build, export, or query Alfred's local JSON code graph",
    )
    p_code_map_sub = p_code_map.add_subparsers(dest="code_map_command")
    p_code_map_build = p_code_map_sub.add_parser(
        "build",
        help="scan a local repo path and write a code-map JSON snapshot",
    )
    p_code_map_build.add_argument("repo", help="local git checkout path; '.' keeps repo key '.'")
    p_code_map_build.add_argument("--name", dest="repo_name", help="repo key in the map")
    p_code_map_build.add_argument("--output", dest="output_path", help="code-map.json output path")
    p_code_map_build.add_argument("--json", action="store_true")
    p_code_map_build.set_defaults(func=cmd_code_map)

    p_code_map_export = p_code_map_sub.add_parser("export", help="emit alfred-codegraph@1 JSON")
    p_code_map_export.add_argument(
        "--format",
        default="alfred-codegraph@1",
        help="export format; currently only alfred-codegraph@1",
    )
    p_code_map_export.add_argument("--map", dest="map_path", help="code-map.json path")
    p_code_map_export.add_argument(
        "--summary-only",
        action="store_true",
        help="omit raw files and edges from the export",
    )
    p_code_map_export.set_defaults(func=cmd_code_map)

    p_code_map_summary = p_code_map_sub.add_parser("summary", help="summarize mapped repos")
    p_code_map_summary.add_argument("repo", nargs="?")
    p_code_map_summary.add_argument("--map", dest="map_path", help="code-map.json path")
    p_code_map_summary.add_argument("--limit", type=int, default=25)
    p_code_map_summary.add_argument("--json", action="store_true")
    p_code_map_summary.set_defaults(func=cmd_code_map)

    p_code_map_impact = p_code_map_sub.add_parser(
        "impact", help="show local import and contract impact for a repo path"
    )
    p_code_map_impact.add_argument("repo")
    p_code_map_impact.add_argument("path")
    p_code_map_impact.add_argument("--map", dest="map_path", help="code-map.json path")
    p_code_map_impact.add_argument("--limit", type=int, default=50)
    p_code_map_impact.add_argument(
        "--brief",
        action="store_true",
        help="render a prompt-ready blast-radius briefing for this path",
    )
    p_code_map_impact.add_argument("--json", action="store_true")
    p_code_map_impact.set_defaults(func=cmd_code_map)

    p_code_map_blast = p_code_map_sub.add_parser(
        "blast-radius", help="summarize local graph impact for changed paths"
    )
    p_code_map_blast.add_argument("repo")
    p_code_map_blast.add_argument("paths", nargs="+")
    p_code_map_blast.add_argument("--map", dest="map_path", help="code-map.json path")
    p_code_map_blast.add_argument("--limit", type=int, default=50)
    p_code_map_blast.add_argument("--json", action="store_true")
    p_code_map_blast.set_defaults(func=cmd_code_map)
    p_code_map.set_defaults(func=cmd_code_map, code_map_command="export")

    p_capabilities = sub.add_parser(
        "capabilities",
        help="inspect local code graph, token, and skill capabilities",
    )
    p_capabilities.add_argument("--json", action="store_true")
    p_capabilities.set_defaults(func=cmd_capabilities)

    p_batteries = sub.add_parser(
        "batteries",
        help="list or toggle Alfred's opt-in enhancements (memory, compression, code graph)",
    )
    p_batteries.add_argument("--json", action="store_true", help="emit the manifest as JSON")
    p_batteries.set_defaults(func=cmd_batteries, battery_action="list")
    batteries_sub = p_batteries.add_subparsers(dest="battery_action")
    p_batteries_list = batteries_sub.add_parser("list", help="list all batteries with status")
    p_batteries_list.add_argument("--json", action="store_true")
    p_batteries_list.set_defaults(func=cmd_batteries, battery_action="list")
    for verb in ("enable", "disable"):
        p_verb = batteries_sub.add_parser(verb, help=f"{verb} one opt-in battery by id")
        p_verb.add_argument("battery_id", help="battery id, e.g. dense-embeddings")
        p_verb.add_argument("--yes", action="store_true", help="run any install without prompting")
        p_verb.add_argument(
            "--print-command",
            action="store_true",
            help="print the install command instead of running it",
        )
        p_verb.add_argument("--json", action="store_true")
        p_verb.set_defaults(func=cmd_batteries, battery_action=verb)

    p_github_poll = sub.add_parser("github-poll", help="poll GitHub issues/PRs into fleet-brain")
    p_github_poll.add_argument("--repo", action="append")
    p_github_poll.add_argument("--state", choices=["open", "closed", "all"], default="all")
    p_github_poll.add_argument("--limit", type=int, default=100)
    p_github_poll.add_argument("--db")
    p_github_poll.add_argument("--dry-run", action="store_true")
    p_github_poll.add_argument("--json", action="store_true")
    p_github_poll.set_defaults(func=cmd_github_poll)

    p_mcp = sub.add_parser("mcp", help="serve read-only Alfred MCP tools")
    p_mcp.add_argument("mcp_args", nargs=argparse.REMAINDER)
    p_mcp.set_defaults(func=cmd_mcp)

    p_demo = sub.add_parser(
        "demo",
        help="watch the team plan, build, catch a bug, and ship in a minute (needs claude)",
    )
    p_demo.add_argument(
        "--keep", action="store_true", help="keep the throwaway demo repo and print its path"
    )
    p_demo.add_argument(
        "--yes", action="store_true", help="auto-approve the plan gate without waiting for Enter"
    )
    p_demo.add_argument("--timeout", type=int, help="per-step engine wall-clock ceiling in seconds")
    p_demo.set_defaults(func=cmd_demo)

    p_serve = sub.add_parser("serve", help="open the read-only localhost dashboard")
    p_serve.add_argument("--host", help="bind address passed to alfred-serve")
    p_serve.add_argument("--port", type=int, help="bind port passed to alfred-serve")
    p_serve.add_argument("--no-browser", action="store_true", help="do not auto-open a browser tab")
    p_serve.add_argument(
        "--log-level",
        choices=["debug", "info", "warning", "error"],
        help="uvicorn log level passed to alfred-serve",
    )
    p_serve.set_defaults(func=cmd_serve)

    p_schedule = sub.add_parser("schedule", help="inspect or edit configured agent cadences")
    p_schedule.add_argument("schedule_args", nargs=argparse.REMAINDER)
    p_schedule.set_defaults(func=cmd_schedule)

    p_assign = sub.add_parser("assign", help="route an existing issue to the right agent lane")
    p_assign.add_argument("issue", help="issue URL or owner/repo#N")
    p_assign.add_argument("--dry-run", action="store_true")
    p_assign.add_argument("--json", action="store_true")
    p_assign.set_defaults(func=cmd_assign)

    p_spec = sub.add_parser("spec", help="create and lint specs for agent work")
    p_spec.add_argument("spec_args", nargs=argparse.REMAINDER)
    p_spec.set_defaults(func=cmd_spec)

    p_goal = sub.add_parser("goal", help="manage the durable goal ledger")
    p_goal.add_argument("goal_args", nargs=argparse.REMAINDER)
    p_goal.set_defaults(func=cmd_goal)

    p_slack_listener = sub.add_parser(
        "slack-listener",
        aliases=["slack"],
        help="run or test the Slack planning listener",
    )
    p_slack_listener.add_argument("listener_args", nargs=argparse.REMAINDER)
    p_slack_listener.set_defaults(func=cmd_slack_listener)

    p_slack_thread_sync = sub.add_parser(
        "slack-thread-sync",
        help="post fleet progress (claimed/PR/CI/merged) to issue-filing Slack threads",
    )
    p_slack_thread_sync.add_argument("--json", action="store_true", help="emit a JSON summary")
    p_slack_thread_sync.add_argument(
        "--dry-run", action="store_true", help="compute deltas without posting to Slack"
    )
    p_slack_thread_sync.add_argument(
        "--state-root", help="override the thread-status state directory"
    )
    p_slack_thread_sync.set_defaults(func=cmd_slack_thread_sync)

    p_shipped = sub.add_parser("shipped", help="summarize shipped GitHub activity")
    p_shipped.add_argument("--period", choices=["daily", "weekly"], default="daily")
    p_shipped.add_argument("--days", type=int)
    p_shipped.add_argument("--since")
    p_shipped.add_argument("--until")
    p_shipped.add_argument("--repo", action="append")
    p_shipped.add_argument("--json", action="store_true")
    p_shipped.add_argument("--slack", action="store_true")
    p_shipped.add_argument("--no-file-scan", action="store_true")
    p_shipped.add_argument(
        "--self-proof",
        action="store_true",
        help="compute only the share of merged PRs shipped by Alfred agents",
    )
    p_shipped.add_argument(
        "--with-self-proof",
        action="store_true",
        help="append the self-proof share to the shipped summary",
    )
    p_shipped.add_argument("--self-proof-days", type=int)
    p_shipped.add_argument(
        "--self-proof-json",
        metavar="PATH",
        help="write the self-proof stat as JSON to PATH ('-' for stdout)",
    )
    p_shipped.set_defaults(func=cmd_shipped)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
