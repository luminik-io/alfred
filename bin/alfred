    )


def cmd_code_memory(args: argparse.Namespace) -> int:
    script = _HERE / "code-memory-mcp"
    forwarded = args.code_memory_args or ["doctor"]
    if forwarded[0] == "serve":
        timeout = None
    elif forwarded[0] in {"index", "refresh"}:
        timeout = _CODE_MEMORY_INDEX_TIMEOUT_S
    else:
        timeout = _DELEGATED_COMMAND_TIMEOUT_S
    return _run_subcommand([str(script), *forwarded], timeout=timeout)


_MEMORY_STATUS_SEVERITY = {"ok": 0, "disabled": 1, "warn": 1, "fail": 2}
_CODE_MEMORY_RELEASE_SHA_RE = re.compile(
    r'^\s*([a-z]+-[a-z0-9]+)\)\s+printf\s+\'%s\'\s+"([0-9a-f]{64})"\s+;;',
    re.MULTILINE,
)
_CODE_MAP_STALE_MINUTES = 24 * 60


def cmd_memory(args: argparse.Namespace) -> int:
    command = getattr(args, "memory_command", "doctor") or "doctor"
    if command != "doctor":
        print("Usage: alfred memory doctor [--json]", file=sys.stderr)
        return 2
    report = run_unified_memory_doctor()
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        _print_memory_doctor(report)
    return 1 if report["status"] == "fail" else 0


def run_unified_memory_doctor(env: dict[str, str] | None = None) -> dict[str, Any]:
    """Read-only readiness report for Alfred's full memory plane."""

    envmap = dict(os.environ if env is None else env)
    providers = _memory_provider_chain_status(envmap)
    redis = _memory_redis_status(providers, envmap)
    fleet = _memory_fleet_brain_status(providers, envmap)
    code_memory = _memory_code_memory_status(envmap)
    code_map = _memory_code_map_status()
    mcp_tools = _memory_mcp_tool_status()
    status = _memory_worst_status(
        [
            providers["status"],
            redis["status"],
            fleet["status"],
            code_memory["status"],
            code_map["status"],
            mcp_tools["status"],
        ]
    )
    return {
        "status": status,
        "checked_at": datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "providers": providers,
        "redis": redis,
        "fleet_brain": fleet,
        "code_memory": code_memory,
        "code_map": code_map,
        "mcp_tools": mcp_tools,
    }


def _memory_worst_status(statuses: list[str]) -> str:
    severity = max((_MEMORY_STATUS_SEVERITY.get(s, 1) for s in statuses), default=0)
    if severity >= _MEMORY_STATUS_SEVERITY["fail"]:
        return "fail"
    if severity >= _MEMORY_STATUS_SEVERITY["warn"]:
        return "warn"
    return "ok"


def _memory_provider_chain_status(env: dict[str, str]) -> dict[str, Any]:
    from memory.config import DEFAULT_PROVIDER_NAMES, PROVIDER_REGISTRY, parse_provider_names

    raw = env.get("ALFRED_MEMORY_PROVIDERS")
    names = list(DEFAULT_PROVIDER_NAMES) if raw is None else parse_provider_names(raw)
    known = sorted(PROVIDER_REGISTRY)
    unknown = [name for name in names if name not in PROVIDER_REGISTRY]
    enabled_names = [name for name in names if name != "null" and name in PROVIDER_REGISTRY]
    disabled = raw is not None and not enabled_names
    if disabled:
        status = "disabled"
        detail = "runtime lesson recall is disabled by ALFRED_MEMORY_PROVIDERS"
    elif unknown:
        status = "warn"
        detail = f"unknown provider(s): {', '.join(unknown)}"
    else:
        status = "ok"
        detail = f"provider chain: {', '.join(names)}"
    return {
        "status": status,
        "source": "default" if raw is None else "env",
        "raw": raw,
        "names": names,
        "enabled_names": enabled_names,
        "default_names": list(DEFAULT_PROVIDER_NAMES),
        "known": known,
        "unknown": unknown,
        "disabled": disabled,
        "detail": detail,
    }


def _memory_redis_status(chain: dict[str, Any], env: dict[str, str]) -> dict[str, Any]:
    names = set(chain.get("enabled_names") or [])
    if "redis" not in names:
        return {
            "status": "disabled",
            "enabled": False,
            "health": None,
            "detail": "redis provider is not in the active memory chain",
        }
    try:
        from memory.redis_agent_memory import RedisAgentMemoryProvider

        provider = RedisAgentMemoryProvider.from_env(env=env)
        health = provider.health()
    except Exception as exc:
        return {
            "status": "warn",
            "enabled": True,
            "health": None,
            "detail": f"redis health check failed before request: {exc}",
        }
    status = "ok" if health.get("ok") else "warn"
    if status == "ok":
        detail = f"Redis AMS reachable at {health.get('base_url')}"
    else:
        detail = f"Redis AMS unavailable at {health.get('base_url')}: {health.get('error')}"
    return {
        "status": status,
        "enabled": True,
        "health": health,
        "detail": detail,
    }


def _memory_fleet_brain_status(chain: dict[str, Any], env: dict[str, str]) -> dict[str, Any]:
    names = set(chain.get("enabled_names") or [])
    if "fleet" not in names:
        return {
            "status": "disabled",
            "enabled": False,
            "report": None,
            "detail": "FleetBrain provider is not in the active memory chain",
        }
    try:
        from fleet_brain.doctor import run_memory_doctor

        report = run_memory_doctor(env.get("ALFRED_FLEET_BRAIN_DB"))
    except Exception as exc:
        return {
            "status": "fail",
            "enabled": True,
            "report": None,
            "detail": f"FleetBrain doctor crashed: {exc}",
        }
    checks = report.get("checks") or []
    problem = next(
        (
            check
            for check in checks
            if check.get("status") in {"fail", "warn"} and check.get("detail")
        ),
        None,
    )
    detail = f"FleetBrain database: {report.get('db')}"
    if problem:
        detail = f"{detail}; {problem.get('name')}: {problem.get('detail')}"
    return {
        "status": report.get("status", "warn"),
        "enabled": True,
        "report": report,
        "detail": detail,
    }


def _memory_code_memory_status(env: dict[str, str]) -> dict[str, Any]:
    try:
        from server.setup import code_memory_status

        status_payload = code_memory_status(env=dict(env))
    except Exception as exc:
        return {
            "status": "fail",
            "enabled": False,
            "detail": f"code-memory status probe crashed: {exc}",
        }

    binary = status_payload.get("binary") or {}
    enabled = bool(status_payload.get("enabled"))
    binary_resolved = bool(binary.get("resolved"))
    index_present = bool(status_payload.get("index_present"))
    if not enabled:
        status = "disabled"
    elif binary_resolved and index_present:
        status = "ok"
    else:
        status = "warn"

    binary_path = binary.get("path") if isinstance(binary.get("path"), str) else None
    platform_tag = _code_memory_platform_tag()
    release_checksum = _code_memory_release_checksum(env, platform_tag)
    status_payload.update(
        {
            "status": status,
            "binary_version": _probe_binary_version(binary_path),
            "binary_sha256": _sha256_file(Path(binary_path)) if binary_path else None,
            "release_archive": {
                "platform_tag": platform_tag,
                **release_checksum,
            },
        }
    )
    return status_payload


def _memory_code_map_status(path: Path | None = None) -> dict[str, Any]:
    try:
        from code_graph import default_code_map_path, load_code_map, summarize_codegraph

        resolved = path or default_code_map_path()
        exists = resolved.exists()
        payload = load_code_map(resolved)
        summary = summarize_codegraph(payload)
    except Exception as exc:
        return {
            "status": "fail",
            "path": str(path) if path else None,
            "exists": False,
            "detail": f"code-map could not be read: {exc}",
        }

    generated_at = summary.get("generated_at")
    age_minutes = _age_minutes(generated_at)
    if not exists:
        status = "warn"
        detail = f"code-map is missing: {resolved}"
    elif age_minutes is None:
        status = "warn"
        detail = "code-map exists but has no generated_at timestamp"
    elif age_minutes > _CODE_MAP_STALE_MINUTES:
        status = "warn"
        detail = f"code-map is stale ({age_minutes}m old)"
    else:
        status = "ok"
        detail = f"code-map is fresh ({age_minutes}m old)"
    return {
        "status": status,
        "path": str(resolved),
        "exists": exists,
        "generated_at": generated_at,
        "age_minutes": age_minutes,
        "repo_count": summary.get("repo_count", 0),
        "contract_drift_count": summary.get("contract_drift_count", 0),
        "detail": detail,
    }


def _memory_mcp_tool_status() -> dict[str, Any]:
    try:
        import importlib

        process_mod = importlib.import_module("agent_runner.process")
        memory_enabled = bool(process_mod._memory_mcp_enabled())
        memory_script = process_mod._memory_mcp_script()
        code_enabled = bool(process_mod._code_memory_mcp_enabled())
        code_launcher = process_mod._code_memory_launcher()
        memory_attached = memory_enabled and memory_script is not None
        code_attached = code_enabled and code_launcher is not None
        memory_tools = process_mod._memory_tool_names() if memory_attached else []
        code_tools = process_mod._code_memory_tool_names() if code_attached else []
    except Exception as exc:
        return {
            "status": "fail",
            "detail": f"MCP tool inventory crashed: {exc}",
        }

    status = _memory_worst_status(
        [
            "ok" if memory_attached else "disabled",
            "ok" if code_attached else "disabled",
        ]
    )
    return {
        "status": status,
        "memory": {
            "server": process_mod.MEMORY_MCP_SERVER,
            "enabled": memory_enabled,
            "attached": memory_attached,
            "script": str(memory_script) if memory_script is not None else None,
            "tools": memory_tools,
        },
        "code_memory": {
            "server": process_mod.CODE_MEMORY_MCP_SERVER,
            "enabled": code_enabled,
            "attached": code_attached,
            "launcher": str(code_launcher) if code_launcher is not None else None,
            "tools": code_tools,
        },
        "allowlist": [*memory_tools, *code_tools],
        "detail": f"{len(memory_tools) + len(code_tools)} read-only MCP tool(s) exposed",
    }


def _code_memory_platform_tag() -> str | None:
    system = platform.system().lower()
    if system == "darwin":
        os_name = "darwin"
    elif system == "linux":
        os_name = "linux"
    else:
        return None
    machine = platform.machine().lower()
    arch = {
        "aarch64": "arm64",
        "arm64": "arm64",
        "amd64": "amd64",
        "x86_64": "amd64",
    }.get(machine)
    if arch is None:
        return None
    return f"{os_name}-{arch}"


def _code_memory_release_checksum(env: dict[str, str], platform_tag: str | None) -> dict[str, Any]:
    if not platform_tag:
        return {"sha256": None, "source": None, "detail": "unsupported platform"}
    override_var = f"ALFRED_CODE_MEMORY_SHA256_{platform_tag.upper().replace('-', '_')}"
    override = env.get(override_var, "").strip()
    if override:
        return {"sha256": override, "source": f"env:{override_var}", "detail": "env override"}
    checksums = _code_memory_release_checksums()
    sha = checksums.get(platform_tag)
    if sha:
        return {"sha256": sha, "source": "launcher-pin", "detail": "pinned release archive"}
    return {"sha256": None, "source": "launcher-pin", "detail": "no checksum pinned"}


def _code_memory_release_checksums() -> dict[str, str]:
    try:
        text = (_HERE / "code-memory-mcp").read_text(encoding="utf-8")
    except OSError:
        return {}
    return {match.group(1): match.group(2) for match in _CODE_MEMORY_RELEASE_SHA_RE.finditer(text)}


def _probe_binary_version(path: str | None) -> dict[str, Any] | None:
    if not path:
        return None
    try:
        res = subprocess.run(
            [path, "--version"],
            check=False,
            capture_output=True,
            text=True,
            timeout=3,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        return {"ok": False, "value": None, "error": str(exc)}
    output = (res.stdout or res.stderr or "").strip().splitlines()
    return {
        "ok": res.returncode == 0,
        "value": output[0][:200] if output else None,
        "returncode": res.returncode,
    }


def _sha256_file(path: Path) -> str | None:
    try:
        digest = hashlib.sha256()
        with path.open("rb") as fh:
            for chunk in iter(lambda: fh.read(1024 * 1024), b""):
                digest.update(chunk)
        return digest.hexdigest()
    except OSError:
        return None


def _age_minutes(raw: object) -> int | None:
    if not isinstance(raw, str) or not raw.strip():
        return None
    try:
        seen = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return None
    if seen.tzinfo is None:
        seen = seen.replace(tzinfo=UTC)
    return max(0, int((datetime.now(UTC) - seen.astimezone(UTC)).total_seconds() // 60))


def _print_memory_doctor(report: dict[str, Any]) -> None:
    print(f"alfred memory doctor: {report['status']}")
    providers = report["providers"]
    provider_names = ", ".join(providers.get("names") or []) or "(disabled)"
    print(f"  {providers['status']:8} providers: {provider_names}")
    for key, label in (
        ("redis", "redis"),
        ("fleet_brain", "fleet-brain"),
        ("code_memory", "code-memory"),
        ("code_map", "code-map"),
        ("mcp_tools", "mcp-tools"),
    ):
        item = report[key]
        print(f"  {item['status']:8} {label}: {item.get('detail') or '-'}")


def cmd_code_map(args: argparse.Namespace) -> int:
    from code_graph import (
        CODEGRAPH_SCHEMA,
        MAX_BLAST_RADIUS_PATHS,
        blast_radius_for_paths,
        export_codegraph,
        impact_brief_for_path,
        impact_for_path,
        load_code_map,
        render_blast_radius,
        render_impact_brief,
        summarize_codegraph,
    )

    map_path = Path(args.map_path).expanduser() if getattr(args, "map_path", None) else None
    command = getattr(args, "code_map_command", "export") or "export"
    if command == "build":
        script = _HERE / "code-map-refresh.py"
        output_path = (
            Path(args.output_path).expanduser() if getattr(args, "output_path", None) else None
        )
        forwarded = [sys.executable, str(script), "--repo", args.repo]
        if getattr(args, "repo_name", None):
            forwarded.extend(["--name", args.repo_name])
        if output_path is not None:
            forwarded.extend(["--output", str(output_path)])
        if args.json:
            forwarded.append("--json")
        env = os.environ.copy()
        checkout_lib = str(_HERE.parent / "lib")
        env["PYTHONPATH"] = (
            checkout_lib
            if not env.get("PYTHONPATH")
            else f"{checkout_lib}{os.pathsep}{env['PYTHONPATH']}"
        )
        return _run_subcommand(forwarded, timeout=_DELEGATED_COMMAND_TIMEOUT_S, env=env)

    if command == "export":
        requested = getattr(args, "format", CODEGRAPH_SCHEMA)
        if requested != CODEGRAPH_SCHEMA:
            print(f"unsupported code-map export format: {requested}", file=sys.stderr)
            return 2
        payload = export_codegraph(
            path=map_path,
            include_files=not bool(getattr(args, "summary_only", False)),
        )
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0

    code_map = load_code_map(map_path)
    if command == "summary":
        payload = summarize_codegraph(
            code_map,
            repo=args.repo,
            path=map_path,
            limit=args.limit,
        )
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
            return 0
        print(
            f"code graph: {payload['repo_count']} repo(s), drift={payload['contract_drift_count']}"
        )
        for repo in payload["repos"]:
            summary = repo["summary"]
            langs = ", ".join(f"{k}:{v}" for k, v in summary["languages"].items()) or "none"
            print(
                f"- {repo['name']}: {summary['files']} files, "
                f"{summary['symbols']} symbols, {summary['imports']} imports, "
                f"endpoints={repo['endpoint_count']}, routes={repo['route_count']}, "
                f"api_calls={repo['api_call_count']}, languages={langs}"
            )
        return 0

    if command == "impact":
        if getattr(args, "brief", False):
            payload = impact_brief_for_path(
                code_map,
                repo=args.repo,
                path=args.path,
                code_map_path=map_path,
                limit=args.limit,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
                return 0
            print(render_impact_brief(payload))
            return 0

        payload = impact_for_path(
            code_map,
            repo=args.repo,
            path=args.path,
            code_map_path=map_path,
            limit=args.limit,
        )
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
            return 0
        print(f"{payload['repo']}:{payload['matched_file'] or payload['path']}")
        print(
            f"symbols={len(payload['symbols'])}, imports={len(payload['imports'])}, "
            f"imported_by={len(payload['imported_by'])}, drift={len(payload['contract_drift'])}"
        )
        if payload["imported_by"]:
            print("imported by:")
            for row in payload["imported_by"]:
                print(f"- {row['from']} -> {row['to']}")
        return 0

    if command == "blast-radius":
        if len(args.paths) > MAX_BLAST_RADIUS_PATHS:
            print(
                f"blast-radius supports at most {MAX_BLAST_RADIUS_PATHS} paths",
                file=sys.stderr,
            )
            return 2
        payload = blast_radius_for_paths(
            code_map,
            repo=args.repo,
            paths=args.paths,
            code_map_path=map_path,
            limit=args.limit,
        )
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
            return 0
        print(render_blast_radius(payload))
        return 0

    print("Usage: alfred code-map {build|export|summary|impact|blast-radius}", file=sys.stderr)
    return 2


def cmd_capabilities(args: argparse.Namespace) -> int:
    from server.setup import capability_status

    payload = capability_status()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0

    print("Alfred capability doctor")
    print(f"ready {payload['summary']['ready']}/{payload['summary']['total']}")
    for item in payload["capabilities"]:
        marker = {
            "ready": "OK",
            "needs_index": "INDEX",
            "installable": "INSTALL",
            "available": "ENABLE",
            "missing": "MISSING",
            "disabled": "OFF",
        }.get(item["state"], item["state"].upper())
        print(f"{marker:<8} {item['title']}: {item['detail']}")
        if item["state"] != "ready":
            print(f"         next: {item['install_hint']}")
    return 0


_BATTERY_STATUS_LABEL = {
    "included": "INCLUDED",
    "enabled": "ENABLED",
    "available": "AVAILABLE",
    "not_installed": "INSTALL",
}


def _print_battery_list(payload: dict[str, Any]) -> None:
    summary = payload.get("summary", {})
    print("Alfred batteries")
    print(
        f"included {summary.get('included', 0)}  enabled {summary.get('enabled', 0)}  "
        f"available {summary.get('available', 0)}  not-installed {summary.get('not_installed', 0)}"
    )
    print("Alfred runs fully with zero batteries; the built-ins are always on.")
    for battery in payload.get("batteries", []):
        marker = _BATTERY_STATUS_LABEL.get(battery["status"], battery["status"].upper())
        daemon = f" (needs {battery['service']})" if battery.get("requires_daemon") else ""
        print(f"{marker:<10} {battery['id']:<20} [{battery['category']}]{daemon}")
        print(f"           {battery['how_it_helps']}")
        if battery["status"] in {"available", "not_installed"} and battery.get("install_hint"):
            print(f"           enable: alfred batteries enable {battery['id']}")
            if battery["status"] == "not_installed":
                print(f"           needs:  {battery['install_hint']}")


def cmd_batteries(args: argparse.Namespace) -> int:
    """List batteries, or enable/disable one opt-in battery.

    Enabling writes the battery's env flag(s) to ``$ALFRED_HOME/.env``. For a
    battery with a pip extra or an autofetch binary, we ask before running the
    install (or print the exact command with ``--print-command``). We NEVER
    install or start a daemon (Redis / Postgres); for those we print setup
    guidance. Idempotent.
    """
    from batteries import (
        battery_by_id,
        disable_values,
        enable_values,
        is_enabled,
        is_installed,
        load_env,
        manifest,
        write_env,
    )

    action = getattr(args, "battery_action", None) or "list"

    if action == "list":
        payload = manifest()
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
            return 0
        _print_battery_list(payload)
        return 0

    battery = battery_by_id(args.battery_id)
    if battery is None:
        print(f"alfred: unknown battery {args.battery_id!r}. Run `alfred batteries` to list them.")
        return 1
    if battery.builtin:
        print(f"alfred: {battery.id} is a built-in and is always on; nothing to change.")
        return 1

    from batteries import enabled_provider_ids

    env_path = _runtime_env_path()
    enabling = action == "enable"
    current_env = load_env()
    # Enabling a second primary memory store (Redis vs pgvector) would compose
    # two primaries into the chain; refuse it with a clear message instead.
    if enabling and battery.provider:
        others = [pid for pid in enabled_provider_ids(current_env) if pid != battery.id]
        if others:
            print(
                f"alfred: {battery.id} conflicts with {', '.join(others)}: both replace the "
                f"primary memory store. Run `alfred batteries disable {others[0]}` first."
            )
            return 1
    # Compose the chain onto the current env so a custom or existing chain is
    # preserved rather than clobbered.
    values = (
        enable_values(battery, current_env) if enabling else disable_values(battery, current_env)
    )
    write_env(env_path, values)
    verb = "enabled" if enabling else "disabled"
    print(f"alfred: {verb} {battery.id}. Wrote {', '.join(values)} to {env_path}")

    if enabling and battery.requires_daemon:
        print(
            f"alfred: {battery.id} needs {battery.service} running, which you must start yourself."
        )
        print(f"        {battery.install_hint}")
        return 0

    if enabling and battery.install_kind in {"pip-extra", "autofetch"}:
        env = load_env()
        if is_enabled(battery, env) and is_installed(battery, env):
            return 0
        return _battery_run_install(args, battery)
    return 0


def _battery_run_install(args: argparse.Namespace, battery: Any) -> int:
    """Prompt for consent and run a battery's install, or print the command."""
    if battery.pip_extra:
        command = [sys.executable, "-m", "pip", "install", f"alfred-os[{battery.pip_extra}]"]
    elif battery.autofetch_cmd:
        command = list(battery.autofetch_cmd)
        # Resolve a bundled launcher (e.g. code-memory-mcp) against Alfred's own
        # bin dir so the command works even when that dir is not on PATH: a bare
        # name would make --print-command unusable and --yes raise FileNotFound.
        launcher = _HERE / command[0]
        if launcher.exists():
            command[0] = str(launcher)
    else:
        return 0
    printable = " ".join(shlex.quote(part) for part in command)

    if getattr(args, "print_command", False):
        print(f"alfred: run this to finish installing {battery.id}:")
        print(f"        {printable}")
        return 0

    if not getattr(args, "yes", False):
        if not sys.stdin.isatty():
            print(f"alfred: {battery.id} still needs its install. Run:")
            print(f"        {printable}")
            return 0
        answer = input(f"alfred: run `{printable}` now? [y/N]: ").strip().lower()
        if not answer.startswith("y"):
            print(f"alfred: skipped. Run it yourself later:\n        {printable}")
            return 0
    print(f"alfred: running {printable}")
    return _run_subcommand(command, timeout=_INSTALL_COMMAND_TIMEOUT_S)


def _pr_min_approvals() -> int:
    import merge_gate

    return merge_gate.parse_min_approvals(os.environ.get("ALFRED_MERGE_MIN_APPROVALS"))


def _default_pr_repo() -> str:
    """Resolve the current checkout's repo under the configured GitHub org."""
    gh_org = os.environ.get("GH_ORG", "").strip()
    if not gh_org:
        raise ValueError("GH_ORG is unset; pass --repo owner/name")
    result = subprocess.run(
        ["git", "remote", "get-url", "origin"],
        check=False,
        capture_output=True,
        text=True,
        timeout=10,
    )
    if result.returncode != 0 or not result.stdout.strip():
        raise ValueError("cannot infer the current repo; pass --repo owner/name")
    repo_name = result.stdout.strip().rstrip("/").removesuffix(".git").rsplit("/", 1)[-1]
    if not repo_name or repo_name == result.stdout.strip():
        raise ValueError("cannot infer the current repo; pass --repo owner/name")
    return f"{gh_org}/{repo_name}"


def cmd_pr(args: argparse.Namespace) -> int:
    """Run the GitHub-native merge gate for one PR (check or merge)."""
    import merge_gate

    try:
        repo = _full_repo_arg(args.repo) if args.repo else _default_pr_repo()
        min_approvals = _pr_min_approvals()
    except ValueError as exc:
        print(f"alfred pr: {exc}", file=sys.stderr)
        return 2

    _snapshot, decision = merge_gate.gate_pull_request(
        repo, args.number, min_approvals=min_approvals
    )

    payload = {
        "repo": repo,
        "number": args.number,
        "headSha": decision.head_sha,
        "mergeable": decision.mergeable,
        "conditions": [
            {"key": c.key, "label": c.label, "passed": c.passed, "detail": c.detail}
            for c in decision.conditions
        ],
    }
    if not args.json:
        print(f"PR {repo}#{args.number} (head {decision.head_sha[:12] or '?'}):")
        print(decision.render())

    if args.pr_command == "check":
        if args.json:
            print(json.dumps(payload, indent=2))
        return 0 if decision.mergeable else 1

    # merge
    if not decision.mergeable:
        if args.json:
            print(json.dumps({**payload, "merged": False}, indent=2))
        else:
            print("Not merging: the gate did not pass.", file=sys.stderr)
        return 1
    ok, msg = merge_gate.guarded_squash_merge(
        repo, args.number, decision.head_sha, delete_branch=not args.no_delete_branch
    )
    if ok:
        if args.json:
            print(json.dumps({**payload, "merged": True}, indent=2))
        else:
            print(f"Merged {repo}#{args.number} (squash, head-guarded {decision.head_sha[:12]}).")
        return 0
    if args.json:
        print(json.dumps({**payload, "merged": False, "error": msg}, indent=2))
    print(f"alfred pr merge: {msg}", file=sys.stderr)
    return 1


