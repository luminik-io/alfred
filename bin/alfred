def _default_enabled(codename: str, script: str = "") -> bool:
    implementation = Path(script).stem if script else codename
    return implementation not in OPT_IN_AGENTS


def _agents_conf_path() -> Path:
    """Return the path to ``agents.conf``.

    Prefers ``$ALFRED_HOME/launchd/agents.conf`` (deployed location);
    falls back to ``<repo>/launchd/agents.conf`` for in-checkout use.
    """
    configured_home = os.environ.get("ALFRED_HOME", "").strip()
    candidates: list[Path] = []
    if configured_home:
        candidates.append(Path(configured_home) / "launchd" / "agents.conf")
    candidates.extend(
        [
            _HERE.parent / "launchd" / "agents.conf",
            _HERE.parent / "launchd" / "agents.conf.example",
        ]
    )
    for p in candidates:
        if p and p.exists():
            return p
    return candidates[-1]


def _parse_agents_conf(path: Path) -> list[dict[str, str]]:
    """Return the list of agent records from ``agents.conf``.

    Each record is a dict with keys ``label, script, schedule, needs_java,
    log_stem, role, disabled``. Custom-agent manifest rows also include
    ``engine``. ``disabled`` is True when the conf line is commented out
    (``#my.fleet.architect ...``).
    """
    out: list[dict[str, str]] = []
    lines = path.read_text().splitlines() if path.exists() else []
    for raw in lines:
        line = raw.rstrip("\n")
        stripped = line.lstrip()
        if not stripped:
            continue
        if stripped.startswith("# ") or stripped == "#":
            continue
        disabled = False
        if stripped.startswith("#"):
            # Heuristic: a commented agent line still has tabs in it.
            # (Plain comments like "# Format: ..." are dropped above.)
            if "\t" not in stripped:
                continue
            disabled = True
            stripped = stripped.lstrip("#").lstrip()
        cols = stripped.split("\t")
        # Pad to 6 columns so missing trailing fields don't IndexError.
        cols = cols + [""] * (6 - len(cols))
        label, script, schedule, needs_java, log_stem, role = cols[:6]
        if not label:
            continue
        out.append(
            {
                "label": label,
                "script": script,
                "schedule": schedule,
                "needs_java": needs_java,
                "log_stem": log_stem,
                "role": role,
                "disabled": "yes" if disabled else "no",
            }
        )
    out.extend(_custom_agent_records())
    return out


def _custom_agent_records() -> list[dict[str, str]]:
    try:
        from custom_agents import CustomAgentStore
    except Exception:
        return []
    try:
        agents = CustomAgentStore.from_env().load()
    except Exception:
        return []
    records: list[dict[str, str]] = []
    for agent in agents:
        records.append(
            {
                "label": agent.label,
                "script": CUSTOM_AGENT_SCRIPT,
                "schedule": agent.schedule,
                "needs_java": "no",
                "log_stem": agent.log_stem,
                "role": agent.role_title,
                "disabled": "no" if agent.enabled else "yes",
                "engine": agent.engine,
            }
        )
    return records


def _codename_from_label(label: str) -> str:
    """Last dot-segment of a launchd label is the codename."""
    return label.rsplit(".", 1)[-1] if "." in label else label


def cmd_agents(_args: argparse.Namespace) -> int:
    conf = _agents_conf_path()
    agents = _parse_agents_conf(conf)
    if not agents:
        print(f"alfred: no agents found at {conf}", file=sys.stderr)
        return 0

    loaded_labels = scheduler.loaded_labels()
    pause_dir = agent_runner.STATE_ROOT / "_paused"
    rows = []
    for a in agents:
        codename = _codename_from_label(a["label"])
        enabled = agent_runner.is_agent_enabled(
            codename,
            default=_default_enabled(codename, a["script"]),
        )
        if (pause_dir / codename).exists():
            loaded = "paused"
        elif a["disabled"] == "yes":
            loaded = "off"
        elif a["label"] in loaded_labels:
            loaded = "yes"
        else:
            loaded = "no"
        rows.append(
            (
                codename,
                a["schedule"] or "-",
                "off" if a["disabled"] == "yes" else "on",
                loaded,
                "yes" if enabled else "no",
                a["role"] or "-",
            )
        )

    headers = ("codename", "schedule", "configured", "loaded", "enabled", "role")
    widths = [max(len(h), max((len(r[i]) for r in rows), default=0)) for i, h in enumerate(headers)]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*("-" * w for w in widths)))
    for r in rows:
        print(fmt.format(*r))

    if not agent_runner.FLEET_ENABLED_FILE.exists():
        print(
            f"\nFleet gate file missing ({agent_runner.FLEET_ENABLED_FILE}); "
            "default-enabled agents are shown as enabled, while opt-in agents "
            "such as `architect` stay disabled until `alfred enable <role-slug>`."
        )
    return 0


def cmd_enable(args: argparse.Namespace) -> int:
    out = agent_runner.enable_agent(args.codename)
    print(f"alfred: enabled {args.codename}")
    print(f"alfred: {len(out)} agent(s) now enabled: {', '.join(out) or '(none)'}")
    return 0


def cmd_disable(args: argparse.Namespace) -> int:
    out = agent_runner.disable_agent(args.codename)
    print(f"alfred: disabled {args.codename}")
    print(f"alfred: {len(out)} agent(s) now enabled: {', '.join(out) or '(none)'}")
    return 0


def cmd_enabled_agents(_args: argparse.Namespace) -> int:
    if not agent_runner.FLEET_ENABLED_FILE.exists():
        print(
            f"alfred: fleet gate file missing ({agent_runner.FLEET_ENABLED_FILE}); "
            "listed opt-in gates are empty, so each runner falls back to its default."
        )
        return 0
    enabled = agent_runner.list_enabled_agents()
    if not enabled:
        print("alfred: 0 agents enabled (file present but empty)")
        return 0
    for c in enabled:
        print(c)
    return 0


def cmd_agent_list(args: argparse.Namespace) -> int:
    try:
        from custom_agents import CustomAgentStore
    except Exception as exc:
        print(f"alfred agent: custom-agent store unavailable: {exc}", file=sys.stderr)
        return 1
    snapshot = CustomAgentStore.from_env().snapshot()
    if args.json:
        print(json.dumps(snapshot, indent=2, sort_keys=True))
        return 0
    agents = snapshot["agents"]
    if not agents:
        print("alfred: no custom runtime agents configured")
        return 0
    for agent in agents:
        status = "enabled" if agent.get("enabled") else "disabled"
        repos = ", ".join(agent.get("repos") or []) or "-"
        print(
            f"{agent['codename']:<28} {status:<8} "
            f"{agent['engine']:<6} {agent['schedule']:<14} "
            f"{agent['role_title']}  repos={repos}"
        )
    return 0


def cmd_agent_add(args: argparse.Namespace) -> int:
    try:
        from custom_agents import CustomAgentError, CustomAgentStore
    except Exception as exc:
        print(f"alfred agent: custom-agent store unavailable: {exc}", file=sys.stderr)
        return 1
    prompt = args.prompt or ""
    if args.prompt_file:
        try:
            prompt = Path(args.prompt_file).expanduser().read_text(encoding="utf-8")
        except OSError as exc:
            print(f"alfred agent add: could not read prompt file: {exc}", file=sys.stderr)
            return 2
    payload = {
        "codename": args.codename,
        "display_name": args.display_name,
        "role_title": args.role_title,
        "purpose": args.purpose or args.role_title,
        "prompt": prompt,
        "engine": args.engine,
        "schedule": args.schedule,
        "repos": args.repo or [],
        "enabled": not args.disabled,
    }
    try:
        agent = CustomAgentStore.from_env().upsert(payload)
    except CustomAgentError as exc:
        print(f"alfred agent add: {exc}", file=sys.stderr)
        return 2
    if args.json:
        print(
            json.dumps(
                {"ok": True, "agent": agent.to_dict(), "deploy_required": True},
                indent=2,
                sort_keys=True,
            )
        )
        return 0
    print(f"alfred: saved custom agent {agent.codename} ({agent.display_name})")
    print(
        "alfred: run `bash deploy.sh` from the source checkout to render or reload the scheduler job"
    )
    return 0


def cmd_agent_remove(args: argparse.Namespace) -> int:
    try:
        from custom_agents import CustomAgentError, CustomAgentStore
    except Exception as exc:
        print(f"alfred agent: custom-agent store unavailable: {exc}", file=sys.stderr)
        return 1
    try:
        removed = CustomAgentStore.from_env().delete(args.codename)
    except CustomAgentError as exc:
        print(f"alfred agent remove: {exc}", file=sys.stderr)
        return 2
    if args.json:
        print(
            json.dumps(
                {"ok": True, "removed": removed, "deploy_required": removed},
                indent=2,
                sort_keys=True,
            )
        )
        return 0
    if removed:
        print(f"alfred: removed custom agent {args.codename}")
        print("alfred: run `bash deploy.sh` from the source checkout to remove the scheduler job")
    else:
        print(f"alfred: no custom agent named {args.codename}")
    return 0


# ----- anonymous usage totals -----


def _runtime_env_path() -> Path:
    return _alfred_home_path() / ".env"


def _read_env_values(path: Path) -> dict[str, str]:
    out: dict[str, str] = {}
    if not path.exists():
        return out
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :]
        if "=" not in line:
            continue
        key, _, value = line.partition("=")
        key = key.strip()
        if not ENV_KEY_RE.match(key):
            continue
        value = _strip_env_inline_comment(value).strip()
        single_quoted = len(value) >= 2 and value[0] == "'" and value[-1] == "'"
        decoded = _decode_env_value(value)
        if not single_quoted:
            home = _safe_home()
            if home is not None:
                home_text = str(home)
                decoded = decoded.replace("${HOME}", home_text).replace("$HOME", home_text)
        out[key] = decoded
    return out


def _strip_env_inline_comment(value: str) -> str:
    quote = ""
    escaped = False
    previous = ""
    for index, char in enumerate(value):
        if escaped:
            escaped = False
            previous = char
            continue
        if char == "\\" and quote != "'":
            escaped = True
            previous = char
            continue
        if quote:
            if char == quote:
                quote = ""
            previous = char
            continue
        if char in ("'", '"'):
            quote = char
            previous = char
            continue
        if char == "#" and previous and previous.isspace():
            return value[:index]
        previous = char
    return value


def _decode_env_value(value: str) -> str:
    if len(value) >= 2 and value[0] == "'" and value[-1] == "'":
        return value[1:-1].replace("'\"'\"'", "'")
    if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
        return value[1:-1]
    return value


def _hydrate_cli_env_from_runtime_env() -> None:
    """Load the canonical runtime ``.env`` before CLI command dispatch.

    The installer no longer writes shell-rc exports, so operator commands must
    see the same single source that scheduled agents see. Match
    ``agent-launch`` precedence: parent-process env wins for ad hoc shell
    overrides, and ``$ALFRED_HOME/.env`` fills the
    scheduler-visible defaults.
    """

    os.environ.pop("ALFREDRC", None)
    # Record whether the operator set ALFRED_HOME themselves BEFORE we default it,
    # so a later call site can tell an explicit home from the injected default.
    global _ALFRED_HOME_EXPLICIT
    _ALFRED_HOME_EXPLICIT = bool(os.environ.get("ALFRED_HOME", "").strip())
    if not _ALFRED_HOME_EXPLICIT:
        os.environ["ALFRED_HOME"] = str(_home_child(".alfred"))
    for key, value in _read_env_values(_runtime_env_path()).items():
        if key == "ALFREDRC" or key in os.environ:
            continue
        os.environ[key] = value
    if not os.environ.get("WORKSPACE_ROOT", "").strip():
        os.environ["WORKSPACE_ROOT"] = str(_home_child("code"))


def _telemetry_values() -> dict[str, str]:
    values = _read_env_values(_runtime_env_path())
    for key in (
        *TELEMETRY_ENV_KEYS,
        TELEMETRY_TRUSTED_TOKEN_ENV,
        DEFAULT_TELEMETRY_URL_ENV,
    ):
        if key in os.environ:
            values[key] = os.environ[key]
    return values


def _telemetry_enabled(values: dict[str, str]) -> bool:
    raw = values.get("ALFRED_TELEMETRY_ENABLED")
    if raw is None:
        return True
    return _switch_value(raw) not in TELEMETRY_DISABLED_VALUES


def _default_telemetry_url(values: dict[str, str] | None = None) -> str:
    source = values or {}
    override = source.get(DEFAULT_TELEMETRY_URL_ENV)
    if override is not None:
        return override.strip()
    return DEFAULT_TELEMETRY_URL


def _telemetry_effective_url(values: dict[str, str]) -> str:
    configured = values.get("ALFRED_TELEMETRY_URL", "").strip()
    return configured or _default_telemetry_url(values)


def _telemetry_previous_clear_url(values: dict[str, str]) -> str:
    try:
        token_endpoint = _telemetry_state_token_endpoint_path().read_text(encoding="utf-8").strip()
    except OSError:
        token_endpoint = ""
    if token_endpoint and _telemetry_state_token_exists():
        return token_endpoint
    configured = values.get("ALFRED_TELEMETRY_URL", "").strip()
    if configured:
        return configured
    return token_endpoint or _default_telemetry_url(values)


def _telemetry_state_token_path() -> Path:
    return agent_runner.STATE_ROOT / TELEMETRY_TOKEN_FILENAME


def _telemetry_state_token_endpoint_path() -> Path:
    return agent_runner.STATE_ROOT / TELEMETRY_TOKEN_ENDPOINT_FILENAME


def _telemetry_state_install_id_path() -> Path:
    return agent_runner.STATE_ROOT / "telemetry-install-id"


def _telemetry_state_token_exists() -> bool:
    try:
        return bool(_telemetry_state_token_path().read_text(encoding="utf-8").strip())
    except OSError:
        return False


def _read_telemetry_state_token() -> str:
    try:
        return _telemetry_state_token_path().read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def _delete_telemetry_state_token() -> bool:
    removed = False
    try:
        _telemetry_state_token_path().unlink()
        removed = True
    except FileNotFoundError:
        pass
    except OSError:
        pass
    try:
        _telemetry_state_token_endpoint_path().unlink()
        removed = True
    except FileNotFoundError:
        pass
    except OSError:
        pass
    return removed


def _delete_telemetry_install_id() -> bool:
    try:
        _telemetry_state_install_id_path().unlink()
        return True
    except FileNotFoundError:
        return False
    except OSError:
        return False


def _quote_env_value(value: str) -> str:
    if "\x00" in value or "\n" in value or "\r" in value:
        raise ValueError("telemetry values must be single-line strings")
    return shlex.quote(value)


def _write_telemetry_env_block(path: Path, values: dict[str, str]) -> None:
    existing = path.read_text(encoding="utf-8") if path.exists() else ""
    existing = TELEMETRY_ENV_BANNER_RE.sub("", existing).strip()
    existing = _strip_telemetry_env_lines(existing).strip()
    block = [TELEMETRY_ENV_BANNER]
    for key in TELEMETRY_ENV_KEYS:
        if key in values and values[key] != "":
            block.append(f"{key}={_quote_env_value(values[key])}")
    block_text = "\n".join(block)

    init_match = ALFRED_INIT_BANNER_RE.search(existing)
    if init_match:
        prefix = existing[: init_match.start()].rstrip()
        suffix = existing[init_match.start() :].lstrip()
        parts = [part for part in (prefix, block_text, suffix) if part]
        new_text = "\n\n".join(parts) + "\n"
    else:
        parts = [part for part in (existing, block_text) if part]
        new_text = "\n\n".join(parts) + "\n"

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f"{path.name}.tmp")
    fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    try:
        os.write(fd, new_text.encode("utf-8"))
    finally:
        os.close(fd)
    os.replace(tmp, path)
    with contextlib.suppress(OSError):
        path.chmod(0o600)


def _strip_telemetry_env_lines(text: str) -> str:
    kept: list[str] = []
    for raw in text.splitlines():
        line = raw.strip()
        if line.startswith("export "):
            line = line[len("export ") :].lstrip()
        key = line.partition("=")[0].strip()
        if key in TELEMETRY_ENV_KEYS:
            continue
        kept.append(raw)
    return "\n".join(kept)


def _alfred_home_path() -> Path:
    configured = os.environ.get("ALFRED_HOME")
    if configured:
        return _safe_expanduser(Path(configured))
    return _home_child(".alfred")


def _install_managed_python_candidates() -> list[Path]:
    """Interpreters provisioned alongside the installed/checked-out code.

    ``_HERE`` is ``<install>/bin``; the deployed fleet ships its venv at
    ``<install>/venv`` and a source checkout at ``<install>/.venv``.
    """
    install_root = _HERE.parent
    return [
        install_root / "venv" / "bin" / "python",
        install_root / ".venv" / "bin" / "python",
    ]


def _alfred_managed_python() -> str:
    """Return the interpreter that runs Alfred's server and helper scripts.

    Precedence:

    1. ``$ALFRED_HOME/venv`` - the requested home's own managed venv.
    2. When ``ALFRED_HOME`` is explicitly set to a home that has no venv of its
       own (a fresh state/config home whose code is loaded from the deployed
       install), the install's own venv. That venv carries the dashboard deps,
       so serve works instead of dying on a bare ``sys.executable`` that lacks
       them. Only the interpreter (and the library it imports) comes from the
       install; ``ALFRED_HOME`` still anchors every state/config path.
    3. ``sys.executable`` as a last resort.
    """
    candidate = _alfred_home_path() / "venv" / "bin" / "python"
    if candidate.is_file() and os.access(candidate, os.X_OK):
        return str(candidate)
    # Only an OPERATOR-set home borrows the install's venv. This must read the
    # pre-hydration flag, not the env var: CLI hydration has already defaulted
    # ALFRED_HOME, so an env check would fire for every default install and a
    # source checkout would silently serve from its own .venv instead of the
    # interpreter the operator invoked.
    if _ALFRED_HOME_EXPLICIT:
        for install_python in _install_managed_python_candidates():
            if install_python.is_file() and os.access(install_python, os.X_OK):
                return str(install_python)
    return sys.executable


def _ensure_requested_home_scaffolding() -> None:
    """Create the minimal state directory for an explicitly-set ``ALFRED_HOME``.

    An operator who points ``ALFRED_HOME`` at a fresh directory expects that
    home to be used for all state/config, even when the code is loaded from the
    deployed install. Create the state directory (rather than silently falling
    back to another home) so the requested home is materialized and honored.
    Only fires for a home the operator set EXPLICITLY. It must read the
    pre-hydration flag, not ``ALFRED_HOME`` from the env: CLI hydration has
    already defaulted the env var to ``~/.alfred``, so scaffolding off the env
    would create ``~/.alfred/state`` on a genuinely fresh default install and
    make ``install_inventory`` report it as initialized, trapping a first run
    out of onboarding.
    """
    if not _ALFRED_HOME_EXPLICIT:
        return
    with contextlib.suppress(OSError):
        (_alfred_home_path() / "state").mkdir(parents=True, exist_ok=True)


def _source_agents_conf_for_root(root: Path) -> Path | None:
    if not (root / "deploy.sh").exists():
        return None
    launchd_dir = root / "launchd"
    if not launchd_dir.exists():
        return None
    return launchd_dir / "agents.conf"


def _telemetry_source_agents_conf_path(alfred_home: Path) -> Path | None:
    """Return the deploy-source ``agents.conf`` when it can be identified."""
    candidates: list[str] = []
    for env_name in ("ALFRED_REPO", "ALFRED_SOURCE_DIR"):
        raw = os.environ.get(env_name, "").strip()
        if raw:
            candidates.append(raw)

    source_marker = alfred_home / "launchd" / TELEMETRY_SOURCE_MARKER
    with contextlib.suppress(OSError):
        raw_marker = source_marker.read_text(encoding="utf-8").strip()
        if raw_marker:
            candidates.append(raw_marker)

    candidates.append(str(_HERE.parent))
    seen: set[str] = set()
    for raw in candidates:
        expanded = os.path.expandvars(raw).strip()
        if not expanded:
            continue
        root = Path(expanded).expanduser()
        try:
            key = str(root.resolve())
        except OSError:
            key = str(root)
        if key in seen:
            continue
        seen.add(key)
        conf = _source_agents_conf_for_root(root)
        if conf is not None:
            return conf
    return None


def _telemetry_agents_conf_path(raw: str | None = None) -> Path:
    if raw:
        return Path(raw).expanduser()
    alfred_home = _alfred_home_path()
    source = _telemetry_source_agents_conf_path(alfred_home)
    if source is not None:
        return source
    runtime = alfred_home / "launchd" / "agents.conf"
    if runtime.exists():
        return runtime
    checkout = _HERE.parent / "launchd" / "agents.conf"
    if checkout.exists():
        return checkout
    return runtime


def _telemetry_row_state(path: Path) -> str:
    if not path.exists():
        return "missing"
    for raw in path.read_text(encoding="utf-8").splitlines():
        stripped = raw.lstrip()
        if stripped.startswith("#"):
            candidate = stripped.lstrip("#").lstrip()
            if candidate.startswith(f"{TELEMETRY_LABEL}\t"):
                return "commented"
        elif stripped.startswith(f"{TELEMETRY_LABEL}\t"):
            return "present"
    return "absent"


def _ensure_telemetry_scheduler_row(path: Path, schedule: str) -> bool:
    row = TELEMETRY_ROW
    if schedule != "interval:3600":
        row = row.replace("\tinterval:3600\t", f"\t{schedule}\t", 1)
    existing = path.read_text(encoding="utf-8") if path.exists() else ""
    lines: list[str] = []
    inserted = False
    changed = not path.exists()
    for raw in existing.splitlines():
        candidate = raw.lstrip().lstrip("#").lstrip()
        if candidate.startswith(f"{TELEMETRY_LABEL}\t"):
            if not inserted:
                lines.append(row)
                inserted = True
            changed = True
            continue
        lines.append(raw)
    if not inserted:
        if lines and lines[-1].strip():
            lines.append("")
        lines.append(row)
        changed = True
    if changed:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    return changed


def _remove_telemetry_scheduler_row(path: Path) -> bool:
    if not path.exists():
        return False
    lines = path.read_text(encoding="utf-8").splitlines()
    kept = [
        raw
        for raw in lines
        if not raw.lstrip().lstrip("#").lstrip().startswith(f"{TELEMETRY_LABEL}\t")
    ]
    if kept == lines:
        return False
    path.write_text("\n".join(kept).rstrip() + "\n", encoding="utf-8")
    return True


def _telemetry_deploy_hint(conf: Path) -> str:
    deploy_sh = conf.parent.parent / "deploy.sh"
    if deploy_sh.exists():
        return f"alfred: run `bash {deploy_sh}` to install the scheduler change"
    return "alfred: run `bash deploy.sh` from the source checkout to install the scheduler change"


def _telemetry_url_error(raw_url: str) -> str | None:
    parsed = urlparse(raw_url)
    if parsed.scheme == "https" and parsed.netloc:
        return None
    host = (parsed.hostname or "").lower()
    if parsed.scheme == "http" and host in {"localhost", "127.0.0.1", "::1"}:
        return None
    return "telemetry endpoint must be HTTPS; localhost HTTP is allowed for local worker tests"


def _telemetry_schedule_error(schedule: str) -> str | None:
    if not schedule:
        return "schedule must not be empty"
    if any(ch in schedule for ch in "\t\r\n"):
        return "schedule must not contain tabs or newlines"
    if schedule.startswith("interval:"):
        raw_seconds = schedule.removeprefix("interval:")
        if raw_seconds.isdigit() and int(raw_seconds) > 0:
            return None
        return "interval schedule must look like interval:1200"
    if schedule.startswith("cron:"):
        raw_parts = schedule.removeprefix("cron:").split(":")
        if len(raw_parts) == 2:
            raw_hour, raw_minute = raw_parts
        elif len(raw_parts) == 3:
            raw_weekday, raw_hour, raw_minute = raw_parts
            if not raw_weekday.isdigit() or not 0 <= int(raw_weekday) <= 6:
                return "weekly cron schedule must use weekday 0-6"
        else:
            return "schedule must look like interval:3600, cron:9:10, or cron:0:22:00"
        if not raw_hour.isdigit() or not 0 <= int(raw_hour) <= 23:
            return "cron schedule hour must be 0-23"
        if not raw_minute.isdigit() or not 0 <= int(raw_minute) <= 59:
            return "cron schedule minute must be 0-59"
        return None
    return "schedule must start with interval: or cron:"


def cmd_telemetry_status(args: argparse.Namespace) -> int:
    env_file = _runtime_env_path()
    conf = _telemetry_agents_conf_path(args.agents_conf)
    values = _telemetry_values()
    enabled = _telemetry_enabled(values)
    url = _telemetry_effective_url(values)
    token = values.get("ALFRED_TELEMETRY_TOKEN", "").strip()
    trusted_token = (
        values.get(TELEMETRY_TRUSTED_TOKEN_ENV, "")
        or os.environ.get(TELEMETRY_TRUSTED_TOKEN_ENV, "")
    ).strip()
    install_id_path = agent_runner.STATE_ROOT / "telemetry-install-id"
    payload = {
        "enabled": enabled,
        "endpoint": url,
        "token_configured": bool(token) or _telemetry_state_token_exists(),
        "trusted_token_configured": bool(trusted_token),
        "env_file": str(env_file),
        "agents_conf": str(conf),
        "scheduler_row": _telemetry_row_state(conf),
        "install_id_path": str(install_id_path),
        "install_id_exists": install_id_path.exists(),
        "token_path": str(_telemetry_state_token_path()),
        "impact_page": "https://alfred.luminik.io/impact/",
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0
    print(f"telemetry: {'on' if enabled else 'off'}")
    print(f"endpoint: {url or '(unset)'}")
    print(f"token: {'set' if payload['token_configured'] else 'unset'}")
    print(f"trusted token: {'set' if payload['trusted_token_configured'] else 'unset'}")
    print(f"scheduler row: {payload['scheduler_row']} ({conf})")
    print(
        f"install id: {'present' if install_id_path.exists() else 'not created'} ({install_id_path})"
    )
    print("public page: https://alfred.luminik.io/impact/")
    if enabled and payload["scheduler_row"] != "present":
        print(
            "warning: usage totals are not scheduled; run `alfred telemetry on`",
            file=sys.stderr,
        )
    return 0


def cmd_telemetry_on(args: argparse.Namespace) -> int:
    env_file = _runtime_env_path()
    conf = _telemetry_agents_conf_path(args.agents_conf)
    current = _telemetry_values()
    url = (
        args.url or current.get("ALFRED_TELEMETRY_URL") or _default_telemetry_url(current)
    ).strip()
    if not url:
        print("alfred telemetry on: no telemetry collector configured", file=sys.stderr)
        return 2
    url_error = _telemetry_url_error(url)
    if url_error:
        print(f"alfred telemetry on: {url_error}", file=sys.stderr)
        return 2
    schedule_error = _telemetry_schedule_error(args.schedule)
    if schedule_error:
        print(f"alfred telemetry on: {schedule_error}", file=sys.stderr)
        return 2
    values = {
        "ALFRED_TELEMETRY_ENABLED": "1",
        "ALFRED_TELEMETRY_URL": url,
    }
    replacement_token = (args.token or "").strip()
    current_token = (current.get("ALFRED_TELEMETRY_TOKEN") or "").strip()
    token = (replacement_token or current_token).strip()
    if token and (not args.clear_token or replacement_token):
        values["ALFRED_TELEMETRY_TOKEN"] = token
    if args.clear_token:
        clear_values = dict(current)
        if not clear_values.get("ALFRED_TELEMETRY_URL"):
            clear_values["ALFRED_TELEMETRY_URL"] = _telemetry_previous_clear_url(current)
        clear_result = _clear_previous_telemetry_report(clear_values)
        clear_status = str(clear_result.get("status") or "")
        clear_done = clear_status in {"sent", "no_url", "no_install_id"}
        if clear_done:
            _delete_telemetry_state_token()
            _delete_telemetry_install_id()
        else:
            retry_token = current_token or _read_telemetry_state_token()
            if retry_token:
                values["ALFRED_TELEMETRY_TOKEN"] = retry_token
                retry_url = str(clear_values.get("ALFRED_TELEMETRY_URL") or "").strip()
                if retry_url:
                    values["ALFRED_TELEMETRY_URL"] = retry_url
            print(
                "warning: kept install id and token so previous usage totals can be cleared later",
                file=sys.stderr,
            )
    _write_telemetry_env_block(env_file, values)
    _ensure_telemetry_scheduler_row(conf, args.schedule)
    print("alfred: telemetry enabled")
    print(f"alfred: wrote {env_file}")
    print(f"alfred: scheduled {TELEMETRY_LABEL} in {conf}")
    print(_telemetry_deploy_hint(conf))
    return 0


def _clear_previous_telemetry_report(values: dict[str, str]) -> dict[str, object]:
    try:
        import proof_telemetry
    except Exception as exc:
        return {"status": "error", "sent": False, "error": str(exc)}
    return proof_telemetry.clear_report(env=values)


def cmd_telemetry_off(args: argparse.Namespace) -> int:
    env_file = _runtime_env_path()
    conf = _telemetry_agents_conf_path(args.agents_conf)
    current = _telemetry_values()
    clear_values = dict(current)
    if not clear_values.get("ALFRED_TELEMETRY_URL"):
        clear_values["ALFRED_TELEMETRY_URL"] = _telemetry_previous_clear_url(current)
    clear_result = _clear_previous_telemetry_report(clear_values)
    clear_status = str(clear_result.get("status") or "")
    clear_done = clear_status in {"sent", "no_url", "no_install_id"}
    values = {"ALFRED_TELEMETRY_ENABLED": "0"}
    keeps_endpoint = not args.forget_endpoint and bool(current.get("ALFRED_TELEMETRY_URL"))
    if not args.forget_endpoint and current.get("ALFRED_TELEMETRY_URL"):
        values["ALFRED_TELEMETRY_URL"] = current["ALFRED_TELEMETRY_URL"]
    if (args.keep_token or (not clear_done and keeps_endpoint)) and current.get(
        "ALFRED_TELEMETRY_TOKEN"
    ):
        values["ALFRED_TELEMETRY_TOKEN"] = current["ALFRED_TELEMETRY_TOKEN"]
    _write_telemetry_env_block(env_file, values)
    removed = _remove_telemetry_scheduler_row(conf)
    if clear_status in {"sent", "no_install_id"}:
        _delete_telemetry_state_token()
    install_id_path = agent_runner.STATE_ROOT / "telemetry-install-id"
    install_id_action = "none"
    if args.delete_install_id and install_id_path.exists():
        if clear_done:
            install_id_path.unlink()
            install_id_action = "removed"
        else:
            install_id_action = "kept"
    print("alfred: telemetry disabled")
    if clear_status == "sent":
        print("alfred: cleared previous usage totals")
    elif not clear_done:
        print("warning: could not clear previous usage totals", file=sys.stderr)
    if install_id_action == "kept":
        print(
            "warning: kept install id so previous usage totals can be cleared later",
            file=sys.stderr,
        )
    print(f"alfred: wrote {env_file}")
    print(f"alfred: {'removed' if removed else 'no'} scheduler row at {conf}")
    print(_telemetry_deploy_hint(conf))
    if args.delete_install_id:
        if install_id_action == "none":
            print(f"alfred: no install id at {install_id_path}")
        else:
            print(f"alfred: {install_id_action} install id at {install_id_path}")
    return 0


# ----- scheduler-backed pause / resume / run -----
#
# alfred-os labels are operator-defined (``my.fleet.senior-dev``,
# ``alfred.cleanup``, ...); there is no fixed prefix to bolt a codename
# onto. So pause/resume/run accept a codename and resolve it to the full
# label via agents.conf. The scheduler module handles the launchd/systemd
# split underneath.


def _label_map() -> dict[str, str]:
    """codename -> full label, from agents.conf (commented rows included)."""
    out: dict[str, str] = {}
    for record in _parse_agents_conf(_agents_conf_path()):
        codename = _codename_from_label(record["label"])
        if codename:
            out.setdefault(codename, record["label"])
    return out


def _record_map() -> dict[str, dict[str, str]]:
    """codename -> canonical agent record.

    A rendered install already has an ``agents.conf``. Treat that file as the
    complete agent roster so dry-run commands do not resurrect old defaults or
    aliases that the operator deliberately did not install. Commented agent
    rows still count: a disabled-only ``agents.conf`` is an intentional
    empty/paused installed roster, not a request to revive fallback defaults.
    Scheduler support rows, such as proof telemetry, do not count as fleet
    agents and cannot suppress the development fallback by themselves.
    """
    out: dict[str, dict[str, str]] = {}
    for record in _parse_agents_conf(_agents_conf_path()):
        codename = _codename_from_label(record["label"])
        script_name = Path(record["script"]).name
        if (
            record["label"] in SUPPORT_SCHEDULER_LABELS
            or codename in SUPPORT_SCHEDULER_CODENAMES
            or script_name in SUPPORT_SCHEDULER_SCRIPTS
        ):
            continue
        if codename:
            out.setdefault(codename, record)
    if out:
        return out
    for codename, defaults in DEFAULT_AGENT_CATALOG.items():
        out.setdefault(
            codename,
            {
                "label": f"alfred.{codename}",
                "script": defaults["script"],
                "schedule": defaults["schedule"],
                "needs_java": "no",
                "log_stem": f"alfred.{codename}",
                "role": defaults["role"],
                "disabled": "no",
            },
        )
    return out


def _resolve_label(name: str) -> str | None:
    """Accept a role slug, active-theme display name, or full label."""
    mapping = _label_map()
    if name in mapping:
        return mapping[name]
    # Already a full label present in agents.conf?
    if name in mapping.values():
        return name
    normalized = _normalize_agent_name(name)
    if normalized != name and normalized in mapping:
        return mapping[normalized]
    return None


def _resolve_agent_record(name: str) -> dict[str, str] | None:
    records = _record_map()
    if name in records:
        return records[name]
    for record in records.values():
        if name == record["label"]:
            return record
    normalized = _normalize_agent_name(name)
    return records.get(normalized)


def _dry_run_payload(record: dict[str, str], args: argparse.Namespace) -> dict[str, str]:
    codename = _codename_from_label(record["label"])
    script = _script_path(record["script"])
    native = args.native and script.name in NATIVE_DRY_RUN_SCRIPTS and not args.simulate
    return {
        "codename": codename,
        "label": record["label"],
        "script": str(script),
        "role": record.get("role") or "-",
        "schedule": record.get("schedule") or "-",
        "mode": "native" if native else "simulated",
        "side_effects": "stubbed" if native else "none",
    }


def _script_path(script: str) -> Path:
    path = Path(script)
    if path.is_absolute():
        return path
    for base in (_HERE, _HERE.parent / "examples" / "bin"):
        candidate = base / script
        if candidate.exists():
            return candidate
    return _HERE / script


def _pause_dir() -> Path:
    return agent_runner.STATE_ROOT / "_paused"


def _pause_one(codename: str, label: str) -> None:
    pause_dir = _pause_dir()
    pause_dir.mkdir(parents=True, exist_ok=True)
    marker = pause_dir / codename
    marker.write_text(datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ") + "\n", encoding="utf-8")
    if scheduler.unit_loaded(label):
        scheduler.unit_unload(label)
        print(f"  paused {codename} (was loaded; unloaded from {scheduler.SCHEDULER})")
    else:
        print(f"  paused {codename} (was not loaded; marker set)")


def _resume_one(codename: str, label: str) -> int:
    marker = _pause_dir() / codename
    if marker.exists():
        marker.unlink()
    unit_path = scheduler.unit_file(label)
    if unit_path is None or not unit_path.exists():
        where = unit_path if unit_path is not None else "(no scheduler on this host)"
        print(f"  {codename}: no unit file at {where}; run `bash deploy.sh` first", file=sys.stderr)
        return 1
    if scheduler.unit_loaded(label):
        print(f"  resumed {codename} (already loaded; marker cleared)")
        return 0
    detail = scheduler.unit_load(label, unit_path)
    suffix = f" ({detail})" if detail else ""
    print(f"  resumed {codename}{suffix}")
    return 0


def cmd_pause(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred pause: no supported host scheduler ({scheduler.SCHEDULER}); "
            "pause/resume need launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    mapping = _label_map()
    targets = sorted(mapping) if args.codename == "all" else [args.codename]
    rc = 0
    for codename in targets:
        label = mapping.get(codename) or _resolve_label(codename)
        if label is None:
            print(f"alfred pause: unknown agent '{codename}'", file=sys.stderr)
            rc = 1
            continue
        _pause_one(_codename_from_label(label), label)
    return rc


def cmd_resume(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred resume: no supported host scheduler ({scheduler.SCHEDULER}); "
            "pause/resume need launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    mapping = _label_map()
    targets = sorted(mapping) if args.codename == "all" else [args.codename]
    rc = 0
    for codename in targets:
        label = mapping.get(codename) or _resolve_label(codename)
        if label is None:
            print(f"alfred resume: unknown agent '{codename}'", file=sys.stderr)
            rc = 1
            continue
        rc = _resume_one(_codename_from_label(label), label) or rc
    return rc


def cmd_run(args: argparse.Namespace) -> int:
    if not scheduler.supported():
        print(
            f"alfred run: no supported host scheduler ({scheduler.SCHEDULER}); "
            "run needs launchd (macOS) or systemd --user (Linux).",
            file=sys.stderr,
        )
        return 2
    if args.codename == "all":
        print(
            "alfred run: 'all' is intentionally not supported (would stampede the host)",
            file=sys.stderr,
        )
        return 2
    label = _resolve_label(args.codename)
    if label is None:
        print(f"alfred run: unknown agent '{args.codename}'", file=sys.stderr)
        return 1
    codename = _codename_from_label(label)
    if not args.force and (_pause_dir() / codename).exists():
        print(f"  {codename}: paused; pass --force to override", file=sys.stderr)
        return 1
    if not scheduler.unit_loaded(label):
        print(f"  {codename}: not loaded; run `alfred resume {codename}` first", file=sys.stderr)
        return 1
    detail = scheduler.unit_kickstart(label)
    suffix = f" ({detail})" if detail else ""
    print(f"  kicked {codename}{suffix}")
    return 0


def cmd_dry_run(
    args: argparse.Namespace, *, resolved_launcher_env: dict[str, str] | None = None
) -> int:
    launcher_env = (
        dict(resolved_launcher_env)
        if resolved_launcher_env is not None
        else agent_runner.launcher_env()
    )
    previous_env = os.environ.copy()
    os.environ.update(launcher_env)
    try:
        if args.codename == "all":
            records = _record_map()
            if args.json:
                payloads = [
                    _dry_run_payload(records[codename], args) for codename in sorted(records)
                ]
                print(json.dumps(payloads, indent=2))
                return 0
            rc = 0
            for codename in sorted(records):
                child_args = argparse.Namespace(
                    codename=codename,
                    native=args.native,
                    simulate=args.simulate,
                    json=False,
                )
                rc = cmd_dry_run(child_args, resolved_launcher_env=launcher_env) or rc
                print("")
            return rc
        record = _resolve_agent_record(args.codename)
        if record is None:
            print(f"alfred dry-run: unknown agent '{args.codename}'", file=sys.stderr)
            return 1
        script = _script_path(record["script"])
        native = args.native and script.name in NATIVE_DRY_RUN_SCRIPTS and not args.simulate
        payload = _dry_run_payload(record, args)
        codename = payload["codename"]
        if args.json:
            print(json.dumps(payload, indent=2))
            return 0
        print(f"alfred dry-run: {codename}")
        print(f"  role: {payload['role']}")
        print(f"  label: {payload['label']}")
        print(f"  script: {payload['script']}")
        print(f"  schedule: {payload['schedule']}")
        if not script.exists():
            print("  status: script missing; deploy or install the runner first")
            return 1
        if not native:
            print("  mode: safe simulation")
            print(
                "  would: resolve config, acquire the agent lock, run preflight, and enter the runner"
            )
            print(
                "  would not: call the host scheduler, mutate GitHub, post Slack, invoke an LLM, or edit files"
            )
            if args.native:
                print("  note: native lifecycle dry-run is not declared for this runner yet")
            else:
                print("  note: pass --native to execute supported runner dry-run hooks")
            return 0
        env = dict(launcher_env)
        pythonpath = str(_HERE.parent / "lib")
        if env.get("PYTHONPATH", "").strip():
            pythonpath = f"{pythonpath}{os.pathsep}{env['PYTHONPATH']}"
        env.update(
            {
                "ALFRED_DRY_RUN": "1",
                "AGENT_CODENAME": codename,
                "LAUNCHD_LABEL": record["label"],
                "PYTHONPATH": pythonpath,
            }
        )
        cmd = [sys.executable, str(script), "--dry-run"]
        print("  mode: native lifecycle dry-run")
        print(f"  exec: {shlex.join(cmd)}")
        return _run_subcommand(cmd, timeout=_NATIVE_DRY_RUN_TIMEOUT_S, env=env)
    finally:
        os.environ.clear()
        os.environ.update(previous_env)


def _agent_name_key(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "-", value.strip().lower()).strip("-")


def _active_theme_agent_aliases() -> dict[str, str]:
    try:
        from roster_theme_store import BASE_THEME_NAMES, RosterThemeStore
    except Exception:
        return {}
    try:
        alfred_home = os.environ.get("ALFRED_HOME", "").strip()
        state_root = (
            Path(alfred_home).expanduser() / "state" if alfred_home else agent_runner.STATE_ROOT
        )
        state = RosterThemeStore.from_state_root(state_root).load()
    except Exception:
        return {}
    out: dict[str, str] = {}
    for codename in BASE_THEME_NAMES:
        themed_name = state.themed_name_for(codename)
        if themed_name:
            out[_agent_name_key(themed_name)] = codename
    return out


def _normalize_agent_name(agent: str) -> str:
    raw = agent.strip()
    slug = raw.lower()
    if slug in DEFAULT_AGENT_CATALOG:
        return slug
    themed = _active_theme_agent_aliases().get(_agent_name_key(raw))
    return themed or slug


def _engine_state_file(agent: str) -> Path:
    return agent_runner.STATE_ROOT / "engines" / agent


def _engine_agent_codenames() -> tuple[str, ...]:
    seen = list(ENGINE_AGENTS)
    for record in _parse_agents_conf(_agents_conf_path()):
        if Path(record["script"]).name not in ENGINE_SCRIPTS:
            continue
        codename = _codename_from_label(record["label"])
        if codename and codename not in seen:
            seen.append(codename)
    return tuple(seen)


def _engine_default(agent: str) -> str:
    for record in _parse_agents_conf(_agents_conf_path()):
        if Path(record["script"]).name != CUSTOM_AGENT_SCRIPT:
            continue
        if _codename_from_label(record["label"]) == agent:
            return agent_runner.normalize_engine(record.get("engine"), default="hybrid")
    return "hybrid"


def _engine_behavior(mode: str) -> str:
    resolved = agent_runner.normalize_engine(mode)
    if resolved == "claude":
        return "Claude Code only"
    if resolved == "codex":
        return "Codex only"
    return "Claude Code first, Codex fallback only on capability gaps"


def _require_engine_agent(agent: str) -> str:
    normalized = _normalize_agent_name(agent)
    supported_agents = _engine_agent_codenames()
    if normalized not in supported_agents:
        supported = ", ".join(supported_agents)
        raise ValueError(f"unsupported engine-aware agent '{normalized}'. Supported: {supported}")
    return normalized


def cmd_engine_status(args: argparse.Namespace) -> int:
    if args.agent:
        try:
            agent = _require_engine_agent(args.agent)
        except ValueError as e:
            print(f"alfred engine: {e}", file=sys.stderr)
            return 2
        mode = agent_runner.agent_engine(agent, default=_engine_default(agent))
        print(f"{agent} engine: {mode}")
        print(f"state file: {_engine_state_file(agent)}")
        print(f"behavior: {_engine_behavior(mode)}")
        return 0

    headers = ("agent", "engine", "behavior")
    rows = []
    for agent in _engine_agent_codenames():
        mode = agent_runner.agent_engine(agent, default=_engine_default(agent))
        rows.append((agent, mode, _engine_behavior(mode)))
    widths = [max(len(h), max((len(r[i]) for r in rows), default=0)) for i, h in enumerate(headers)]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*("-" * w for w in widths)))
    for row in rows:
        print(fmt.format(*row))
    return 0


def cmd_engine_set(args: argparse.Namespace) -> int:
    try:
        agent = _require_engine_agent(args.agent)
    except ValueError as e:
        print(f"alfred engine: {e}", file=sys.stderr)
        return 2
    mode = agent_runner.normalize_engine(args.mode)
    target = _engine_state_file(agent)
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(mode + "\n", encoding="utf-8")
    print(f"alfred: {agent} engine set to {mode}")
    print(f"alfred: wrote {target}")
    return 0


def _print_engine_roster() -> None:
    for agent in _engine_agent_codenames():
        mode = agent_runner.agent_engine(agent, default=_engine_default(agent))
        print(f"engine {agent}: {mode} ({_engine_behavior(mode)})")


def _codex_status() -> int:
    binary = agent_runner.CODEX_BIN
    binary_path = Path(binary)
    resolved = str(binary_path) if binary_path.is_absolute() and binary_path.exists() else None
    if not resolved and not binary_path.is_absolute():
        resolved = shutil.which(binary)
    if not resolved:
        print(f"codex: not found on PATH ({binary})", file=sys.stderr)
        print(
            "Set CODEX_BIN in $ALFRED_HOME/.env or install/sign in to Codex CLI.", file=sys.stderr
        )
        return 1

    print(f"codex binary: {resolved}")
    result = subprocess.run(
        [resolved, "--version"],
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )
    version = (result.stdout or result.stderr).strip()
    if version:
        print(f"codex version: {version}")
    else:
        print(f"codex version: unavailable (exit {result.returncode})")
    print("")
    _print_engine_roster()
    print("")
    print("Probe with: alfred codex probe")
    return 0 if result.returncode == 0 else result.returncode


def _probe_codex() -> int:
    binary = agent_runner.CODEX_BIN
    binary_path = Path(binary)
    resolved = str(binary_path) if binary_path.is_absolute() and binary_path.exists() else None
    if not resolved and not binary_path.is_absolute():
        resolved = shutil.which(binary)
    if not resolved:
        print(f"codex probe: failed; binary not found ({binary})", file=sys.stderr)
        return 1

    probe_dir = Path.cwd()
    if not (probe_dir / ".git").exists():
        probe_dir = _HERE.parent
    out_dir = Path(tempfile.mkdtemp(prefix="alfred-codex-probe-"))
    last = out_dir / "last.md"
    prompt = "Reply with exactly: ALFRED_CODEX_OK"
    cmd = [
        resolved,
        "exec",
        "--skip-git-repo-check",
        "--cd",
        str(probe_dir),
        "--sandbox",
        "read-only",
        "-c",
        'approval_policy="never"',
        "--output-last-message",
        str(last),
        "-",
    ]
    print(f"Probing Codex CLI auth in {probe_dir}")
    print(f"Probe artifacts: {out_dir}")
    try:
        result = subprocess.run(
            cmd,
            input=prompt,
            check=False,
            capture_output=True,
            text=True,
            timeout=120,
        )
    except subprocess.TimeoutExpired:
        print("Codex probe: failed")
        print("codex probe timed out after 120s", file=sys.stderr)
        return 1

    (out_dir / "stdout.txt").write_text(result.stdout or "", encoding="utf-8")
    (out_dir / "stderr.txt").write_text(result.stderr or "", encoding="utf-8")
    body = ""
    if last.exists():
        body = last.read_text(encoding="utf-8", errors="replace").strip()
    if result.returncode == 0 and "ALFRED_CODEX_OK" in body:
        print("Codex probe: ok")
        print(f"last message: {last}")
        return 0
    print("Codex probe: failed")
    if body:
        print(f"last message: {body[:500]}")
    tail = (result.stderr or result.stdout or "")[-800:].strip()
    if tail:
        print(tail)
    return 1


def cmd_codex(args: argparse.Namespace) -> int:
    command = args.codex_command
    if command in ("status", ""):
        return _codex_status()
    if command == "probe":
        return _probe_codex()
    print("Usage: alfred codex {status|probe}", file=sys.stderr)
    return 2


def cmd_metrics(args: argparse.Namespace) -> int:
    script = _HERE / "alfred-metrics.py"
    cmd = [sys.executable, str(script)]
    if args.since is not None:
        cmd.extend(["--since", args.since])
    if args.days is not None:
        cmd.extend(["--days", str(args.days)])
    for codename in args.codename or []:
        cmd.extend(["--codename", codename])
    if args.by_day:
        cmd.append("--by-day")
    if args.json:
        cmd.append("--json")
    return _run_subcommand(cmd, timeout=_DELEGATED_COMMAND_TIMEOUT_S)


def cmd_benchmark(args: argparse.Namespace) -> int:
    script = _HERE / "alfred-benchmark.py"
    forwarded = args.benchmark_args or []
    return _run_subcommand(
        [sys.executable, str(script), *forwarded],
        timeout=_BENCHMARK_COMMAND_TIMEOUT_S,
    )


