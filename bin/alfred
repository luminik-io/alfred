_EXTRA_BOOTSTRAP_LABELS: tuple[tuple[str, str, str], ...] = (
    ("agent:authored", "1d76db", "PR authored by an Alfred agent."),
    (
        "agent:plan-pending-approval",
        "fbca04",
        "The architect role drafted a plan and is waiting for operator approval.",
    ),
    ("do-not-review", "cccccc", "Operator override: automated reviewers must skip this PR."),
    ("do-not-merge", "b60205", "Operator override: automerge must skip this PR."),
    ("needs:info", "d4c5f9", "Reporter needs to provide more detail."),
    ("needs:triage", "fef2c0", "Needs triage."),
    ("bug", "ee0701", "Confirmed bug."),
    ("test-coverage", "bfdadc", "Test coverage work."),
    ("severity:p0", "b60205", "Production broken, data loss, or security leak."),
    ("severity:p1", "d93f0b", "User-visible bug, not blocking."),
    ("severity:p2", "fbca04", "Minor or polish issue."),
    ("severity:p3", "0e8a16", "Trivial or won't fix."),
)


def _label_bootstrap_catalog() -> list[tuple[str, str, str]]:
    """Return the repo label catalogue used by setup and standalone bootstrap."""
    out: dict[str, tuple[str, str, str]] = {}
    for name, color, desc in (
        *agent_runner.LIFECYCLE_LABELS,
        *agent_runner.STANDARD_LABELS,
        *_EXTRA_BOOTSTRAP_LABELS,
    ):
        out.setdefault(name, (name, color, desc))
    return list(out.values())


def _full_repo_arg(repo: str) -> str:
    if "/" in repo:
        return repo
    gh_org = os.environ.get("GH_ORG", "").strip()
    if not gh_org:
        raise ValueError(f"GH_ORG is unset; pass a full repo slug like owner/{repo}")
    return f"{gh_org}/{repo}"


def _fleet_repos_from_env() -> list[str]:
    """Collect repos from the fleet's comma-separated repo env vars."""
    keys = [k for k in os.environ if k.startswith("ALFRED_") and k.endswith("_REPOS")]
    keys.extend(["LABEL_STATE_SWEEP_REPOS", "ALFRED_CLAIM_SWEEP_REPOS"])
    seen: set[str] = set()
    repos: list[str] = []
    for key in keys:
        for raw in os.environ.get(key, "").split(","):
            repo = raw.strip()
            if not repo or repo in seen:
                continue
            seen.add(repo)
            repos.append(repo)
    return repos


def _load_repo_labels(repo: str) -> dict[str, dict[str, str]]:
    result = subprocess.run(
        ["gh", "label", "list", "-R", repo, "--json", "name,color,description", "--limit", "500"],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip()
        raise RuntimeError(f"gh label list failed for {repo}: {detail}")
    try:
        labels = json.loads(result.stdout or "[]")
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"gh label list returned invalid JSON for {repo}: {exc}") from exc
    return {
        str(row.get("name")): {
            "color": str(row.get("color") or "").lstrip("#").lower(),
            "description": str(row.get("description") or ""),
        }
        for row in labels
        if row.get("name")
    }


def _gh_label_create(repo: str, name: str, color: str, desc: str) -> int:
    result = subprocess.run(
        [
            "gh",
            "label",
            "create",
            name,
            "--color",
            color,
            "--description",
            desc,
            "-R",
            repo,
        ],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        print((result.stderr or result.stdout).strip(), file=sys.stderr)
    return result.returncode


def _gh_label_edit(repo: str, name: str, color: str, desc: str) -> int:
    result = subprocess.run(
        [
            "gh",
            "label",
            "edit",
            name,
            "--color",
            color,
            "--description",
            desc,
            "-R",
            repo,
        ],
        check=False,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        print((result.stderr or result.stdout).strip(), file=sys.stderr)
    return result.returncode


def _labels_bootstrap_one(repo_arg: str, *, check: bool, force: bool) -> int:
    try:
        repo = _full_repo_arg(repo_arg)
    except ValueError as exc:
        print(f"alfred labels: {exc}", file=sys.stderr)
        return 2

    try:
        existing = _load_repo_labels(repo)
    except RuntimeError as exc:
        print(f"alfred labels: {exc}", file=sys.stderr)
        return 1

    print(f"==> labels {'check' if check else 'bootstrap'} on {repo}")
    rc = 0
    missing: list[tuple[str, str, str]] = []
    for name, color, desc in _label_bootstrap_catalog():
        current = existing.get(name)
        if current is None:
            missing.append((name, color, desc))
            if check:
                print(f"  x {name} (MISSING)")
                continue
            created = _gh_label_create(repo, name, color, desc)
            if created == 0:
                print(f"  + {name}")
            else:
                rc = 1
            continue
        color_match = current["color"] == color.lower()
        desc_match = current["description"] == desc
        if force and not check and (not color_match or not desc_match):
            edited = _gh_label_edit(repo, name, color, desc)
            if edited == 0:
                print(f"  ~ {name}")
            else:
                rc = 1
        else:
            print(f"  ok {name}")

    if check and missing:
        print(f"  Run `alfred labels bootstrap {repo_arg}` to add {len(missing)} missing label(s).")
        return 1
    if not check and rc == 0:
        print(f"  ok {len(missing)} label(s) bootstrapped")
    return rc


def cmd_labels(args: argparse.Namespace) -> int:
    if args.labels_command == "check":
        args.check = True
    if args.all:
        repos = _fleet_repos_from_env()
        if not repos:
            print(
                "alfred labels: --all found no ALFRED_*_REPOS or LABEL_STATE_SWEEP_REPOS values",
                file=sys.stderr,
            )
            return 2
    else:
        if not args.repo:
            print("alfred labels: repo is required unless --all is passed", file=sys.stderr)
            return 2
        repos = [args.repo]
    rc = 0
    for repo in repos:
        rc = _labels_bootstrap_one(repo, check=args.check, force=args.force) or rc
    return rc


def _lock_dir_for_agent(agent: str) -> Path:
    return Path("/tmp") / f"agent-lock-{agent}"


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def _read_lock_metadata(lock_dir: Path) -> dict[str, object]:
    metadata = lock_dir / "metadata.json"
    if not metadata.exists():
        return {}
    try:
        return json.loads(metadata.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def _read_lock_pid(lock_dir: Path, metadata: dict[str, object]) -> int | None:
    raw = metadata.get("pid")
    if isinstance(raw, int):
        return raw
    pid_file = lock_dir / "pid"
    try:
        return int(pid_file.read_text(encoding="utf-8").strip())
    except (OSError, ValueError):
        return None


def _git_output(args: list[str], cwd: Path) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        check=False,
        capture_output=True,
        text=True,
        timeout=15,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def _matching_worktree_risks(agent: str, *, create_recovery: bool = False) -> list[str]:
    root = agent_runner.WORKTREE_ROOT
    if not root.exists():
        return []
    risks: list[str] = []
    for wt in sorted(root.iterdir()):
        if not wt.is_dir():
            continue
        branch = _git_output(["branch", "--show-current"], wt)
        if agent not in wt.name and agent not in branch:
            continue
        risk = agent_runner.worktree_risk_reason(wt)
        if risk:
            recovery = None
            if create_recovery:
                recovery = agent_runner.create_recovery_ref(wt, branch=branch or None)
            recovery_part = f", recovery={recovery}" if recovery else ""
            risks.append(f"{wt} ({branch or 'unknown branch'}, {risk}{recovery_part})")
    return risks


def _describe_lock(lock_dir: Path, agent: str) -> tuple[int | None, bool, bool | None]:
    metadata = _read_lock_metadata(lock_dir)
    pid = _read_lock_pid(lock_dir, metadata)
    alive = _pid_alive(pid) if pid is not None else False
    identity_status: bool | None = None
    if pid is not None and alive:
        identity_status = agent_runner.lock_pid_identity_status(lock_dir, pid, expected_agent=agent)
    return pid, alive, identity_status


def _clear_lock_scheduler_health(agent: str) -> str:
    label = _resolve_label(agent)
    if label is None:
        return "scheduler: unknown agent label"
    unit_path = scheduler.unit_file(label)
    if unit_path is None:
        return f"scheduler: unsupported on this host ({scheduler.SCHEDULER})"
    if not unit_path.exists():
        return f"scheduler: unit file missing at {unit_path}"
    loaded = scheduler.unit_loaded(label)
    return f"scheduler: {'loaded' if loaded else 'not loaded'} ({scheduler.SCHEDULER})"


def _clear_lock_one(agent: str, *, check: bool, force: bool, quiet: bool) -> int:
    lock_dir = _lock_dir_for_agent(agent)
    print(f"{agent}:")
    print(f"  lock dir: {lock_dir}")
    if not lock_dir.exists():
        print("  state: no lock present")
        return 0
    pid, alive, identity_status = _describe_lock(lock_dir, agent)
    print(f"  pid: {pid if pid is not None else 'unknown'}")
    print(f"  pid alive: {'yes' if alive else 'no'}")
    if identity_status is not None:
        print(f"  identity match: {'yes' if identity_status else 'no'}")
    risks = _matching_worktree_risks(agent, create_recovery=not check)
    for risk in risks:
        print(f"  worktree risk: {risk}")
    if check:
        return 1 if alive or risks else 0
    if pid is None and not force:
        print("  refusing to clear: lock holder pid is unknown; pass --force to override")
        return 1
    if alive and identity_status is not False and not force:
        print("  refusing to clear: lock holder still appears alive; pass --force to override")
        return 1
    if risks and not force:
        print("  refusing to clear: matching worktree has unpushed or dirty work")
        print("  recover the worktree or pass --force after preserving it")
        return 1
    shutil.rmtree(lock_dir, ignore_errors=True)
    print("  cleared")
    health = _clear_lock_scheduler_health(agent)
    print(f"  {health}")
    if not quiet:
        agent_runner.slack_post(f"alfred clear-lock: cleared {agent} lock at {lock_dir}; {health}")
    return 0


def cmd_clear_lock(args: argparse.Namespace) -> int:
    if args.all:
        agents = sorted(
            p.name.removeprefix("agent-lock-")
            for p in Path("/tmp").glob("agent-lock-*")
            if p.is_dir()
        )
        if not agents:
            print("alfred clear-lock: no agent locks found")
            return 0
    else:
        if not args.codename:
            print("alfred clear-lock: codename is required unless --all is passed", file=sys.stderr)
            return 2
        agents = [args.codename]
    rc = 0
    for agent in agents:
        rc = _clear_lock_one(agent, check=args.check, force=args.force, quiet=args.quiet) or rc
    return rc


def _launchctl(args: list[str]) -> subprocess.CompletedProcess[str]:
    return _scheduler_command(["launchctl", *args], timeout=_SCHEDULER_COMMAND_TIMEOUT_S)


def _systemctl_user(args: list[str]) -> subprocess.CompletedProcess[str]:
    return _scheduler_command(["systemctl", "--user", *args], timeout=15)


def _scheduler_command(cmd: list[str], *, timeout: float) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(
            cmd,
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired as exc:
        stdout = (
            exc.stdout.decode(errors="replace")
            if isinstance(exc.stdout, bytes)
            else exc.stdout or ""
        )
        stderr = (
            exc.stderr.decode(errors="replace")
            if isinstance(exc.stderr, bytes)
            else exc.stderr or ""
        )
        detail = f"command timed out after {timeout:g}s"
        return subprocess.CompletedProcess(cmd, 124, stdout=stdout, stderr=f"{stderr}{detail}\n")


def _decode_systemd_env_value(value: str) -> str:
    try:
        if value.startswith("$'") and value.endswith("'"):
            return str(ast.literal_eval("'" + value[2:-1] + "'"))
        if value.startswith(("'", '"')):
            parts = shlex.split(value)
            return parts[0] if parts else ""
    except Exception:
        return value
    return value


def _current_claude_dir() -> str:
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        result = _launchctl(["getenv", "CLAUDE_CONFIG_DIR"])
        if result.returncode != 0:
            return ""
        return result.stdout.strip()
    if scheduler.SCHEDULER == "systemd":
        result = _systemctl_user(["show-environment"])
        if result.returncode != 0:
            return os.environ.get("CLAUDE_CONFIG_DIR", "")
        for line in result.stdout.splitlines():
            key, _, value = line.partition("=")
            if key == "CLAUDE_CONFIG_DIR":
                return _decode_systemd_env_value(value)
        return ""
    return os.environ.get("CLAUDE_CONFIG_DIR", "")


def _current_claude_label() -> str:
    value = _current_claude_dir()
    if not value or value == str(PRIMARY_CLAUDE_DIR):
        return "primary (~/.claude)"
    if value == str(SECONDARY_CLAUDE_DIR):
        return "secondary (~/.claude-secondary)"
    return f"custom ({value})"


def _claude_auth_mtime(path: Path) -> str:
    auth_file = path / ".claude.json"
    if not auth_file.exists():
        return "no .claude.json"
    return datetime.fromtimestamp(auth_file.stat().st_mtime).strftime("%Y-%m-%d %H:%M")


def _count_scheduled_agents() -> int | None:
    if not scheduler.supported():
        return None
    labels = scheduler.loaded_labels()
    prefix = os.environ.get("FLEET_LABEL_PREFIX", "")
    if prefix:
        return sum(1 for label in labels if label.startswith(prefix))
    return sum(
        1 for label in labels if any(token in label for token in ("agent", "fleet", "alfred"))
    )


def _claude_status() -> int:
    print(f"Current routing for scheduled agents: {_current_claude_label()}")
    print("")
    print("Auth dir state:")
    for label, directory in (
        ("primary:", PRIMARY_CLAUDE_DIR),
        ("secondary:", SECONDARY_CLAUDE_DIR),
    ):
        if directory.exists():
            print(f"  {label:<12} {directory}   (last touched: {_claude_auth_mtime(directory)})")
        else:
            print(f"  {label:<12} {directory}   (NOT PRESENT)")
    print("")
    agent_count = _count_scheduled_agents()
    if agent_count is None:
        print("Live scheduled agents: unavailable (no supported host scheduler)")
    else:
        print(f"Live {scheduler.SCHEDULER} agents: {agent_count}")
    print("")
    print("Switch with: alfred claude {primary|secondary|swap}")
    print("Verify real API auth with: alfred claude probe")
    return 0


def _set_claude_dir(path: Path, label: str) -> int:
    if scheduler.SCHEDULER not in {"launchd", "systemd"}:
        print(
            "alfred claude: no supported host scheduler; set CLAUDE_CONFIG_DIR "
            f"to {path} in your shell or cron.",
            file=sys.stderr,
        )
        return 2
    if label == "secondary" and not path.exists():
        print(f"ERROR: {path} not present. Set it up first:", file=sys.stderr)
        print(f"  CLAUDE_CONFIG_DIR={path} claude   # then complete login", file=sys.stderr)
        return 2
    if scheduler.SCHEDULER == "launchd":
        if not shutil.which("launchctl"):
            print(
                "alfred claude: launchctl is not available; set CLAUDE_CONFIG_DIR "
                f"to {path} manually.",
                file=sys.stderr,
            )
            return 2
        result = _launchctl(["setenv", "CLAUDE_CONFIG_DIR", str(path)])
    else:
        result = _systemctl_user(["set-environment", f"CLAUDE_CONFIG_DIR={path}"])
    if result.returncode != 0:
        print(
            result.stderr.strip()
            or f"alfred claude: {scheduler.SCHEDULER} environment update failed",
            file=sys.stderr,
        )
        return result.returncode
    print(f"Agents now route to {label.upper()} ({path}). Next firing of each agent picks this up.")
    return 0


def _swap_claude_dir() -> int:
    if _current_claude_dir() == str(SECONDARY_CLAUDE_DIR):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")


def _probe_claude_auth() -> int:
    print(f"Probing Claude Code API auth for {_current_claude_label()}")
    print("This sends one tiny non-interactive Claude request when auth is healthy.")
    env = os.environ.copy()
    current = _current_claude_dir()
    if current:
        env["CLAUDE_CONFIG_DIR"] = current
    cmd = [
        "claude",
        "-p",
        "Reply exactly ALFRED_CLAUDE_OK",
        "--output-format",
        "json",
        "--max-turns",
        "1",
        "--model",
        "claude-haiku-4-5",
    ]
    try:
        result = subprocess.run(
            cmd, check=False, capture_output=True, text=True, timeout=90, env=env
        )
    except FileNotFoundError:
        print("Claude probe: failed")
        print("claude binary not found on PATH", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print("Claude probe: failed")
        print("claude probe timed out after 90s", file=sys.stderr)
        return 1

    payload = result.stdout.strip() or result.stderr.strip()
    try:
        data = json.loads(payload)
        body = str(data.get("result") or "")
        summary = (
            f"exit_json subtype={data.get('subtype')} is_error={data.get('is_error')} "
            f"api_error_status={data.get('api_error_status')} result={body[:300]}"
        )
    except json.JSONDecodeError:
        body = payload
        summary = payload[-500:]
    if result.returncode == 0 and "ALFRED_CLAUDE_OK" in body:
        print("Claude probe: ok")
        return 0
    print("Claude probe: failed")
    print(summary)
    return 1


def cmd_skills(args: argparse.Namespace) -> int:
    """Delegate to the shared skills CLI (lib/skills_cli.py).

    Imported lazily so `alfred` startup stays cheap and a missing/broken
    manifest only bites the `alfred skills` verbs, not the whole CLI. The same
    module backs the wheel's `alfred-os skills` entry point, so both surfaces
    behave identically.
    """
    import skills_cli

    return skills_cli.dispatch(args)


def cmd_claude(args: argparse.Namespace) -> int:
    command = args.claude_command
    if command in ("status", ""):
        return _claude_status()
    if command in ("primary", "main"):
        return _set_claude_dir(PRIMARY_CLAUDE_DIR, "primary")
    if command in ("secondary", "2"):
        return _set_claude_dir(SECONDARY_CLAUDE_DIR, "secondary")
    if command in ("swap", "toggle"):
        return _swap_claude_dir()
    if command == "probe":
        return _probe_claude_auth()
    print("Usage: alfred claude {status|primary|secondary|swap|probe}", file=sys.stderr)
    return 2


def cmd_setup_token(args: argparse.Namespace) -> int:
    """Forward to ``bin/alfred-setup-token.py``.

    Keeps the heavy logic out of the dispatcher so the standalone script
    is callable directly (``python3 ~/.alfred/bin/alfred-setup-token.py``)
    for operators who prefer to bypass the ``alfred`` CLI.
    """
    script = _HERE / "alfred-setup-token.py"
    cmd = [sys.executable, str(script)]
    if args.force:
        cmd.append("--force")
    if args.check_only:
        cmd.append("--check-only")
    if args.token:
        cmd.extend(["--token", args.token])
    return _run_subcommand(cmd, timeout=_INTERACTIVE_COMMAND_TIMEOUT_S)


def cmd_architect_setup(args: argparse.Namespace) -> int:
    """Forward to ``bin/alfred-architect-setup.py``."""
    script = _HERE / "alfred-architect-setup.py"
    cmd = [sys.executable, str(script)]
    for attr, flag in (
        ("check_only", "--check-only"),
        ("force", "--force"),
        ("non_interactive", "--non-interactive"),
        ("skip_token_setup", "--skip-token-setup"),
        ("skip_doctor", "--skip-doctor"),
        ("run_slack_tests", "--run-slack-tests"),
    ):
        if getattr(args, attr, False):
            cmd.append(flag)
    for attr, flag in (
        ("slack_bot_token", "--slack-bot-token"),
        ("operator_user_id", "--operator-user-id"),
        ("slack_channel", "--slack-channel"),
        ("parent_repo", "--parent-repo"),
        ("mode", "--mode"),
        ("approval_mode", "--approval-mode"),
        ("picker", "--picker"),
        ("rollout_order", "--rollout-order"),
        ("bundle_slug_prefix", "--bundle-slug-prefix"),
    ):
        value = getattr(args, attr, None)
        if value:
            cmd.extend([flag, str(value)])
    if getattr(args, "approval_timeout_s", None) is not None:
        cmd.extend(["--approval-timeout-s", str(args.approval_timeout_s)])
    return _run_subcommand(cmd, timeout=_INTERACTIVE_COMMAND_TIMEOUT_S)


def cmd_auth(args: argparse.Namespace) -> int:
    command = args.auth_command
    if command in ("status", ""):
        claude_rc = _claude_status()
        print("")
        codex_rc = _codex_status()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    if command == "probe":
        claude_rc = _probe_claude_auth()
        print("")
        codex_rc = _probe_codex()
        return 0 if claude_rc == 0 and codex_rc == 0 else 1
    print("Usage: alfred auth {status|probe}", file=sys.stderr)
    return 2


def main(argv: list[str] | None = None) -> int:
    previous_env = os.environ.copy()
    _hydrate_cli_env_from_runtime_env()

    try:
        return _main_hydrated(argv)
    finally:
        os.environ.clear()
        os.environ.update(previous_env)


