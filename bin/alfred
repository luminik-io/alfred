def _safe_expanduser(path: Path) -> Path:
    try:
        return path.expanduser()
    except RuntimeError:
        return path


def _safe_home() -> Path | None:
    raw = os.environ.get("HOME", "").strip()
    if raw:
        return _safe_expanduser(Path(raw))
    try:
        return Path.home()
    except RuntimeError:
        return None


def _home_child(name: str) -> Path:
    home = _safe_home()
    if home is None:
        return Path(name)
    return home / name


